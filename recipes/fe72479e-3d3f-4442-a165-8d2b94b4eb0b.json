  "instructions": [
    {
      "id": "f8b65499-f557-498f-ab15-8e581ebc5272",
      "url": null,
      "text": "Lístkové cesto vyvaľkáme natenko (1-2 mm). Nakrájeme pásiky 5x35 cm, potrieme ich natenko lekvárom a posypeme škoricovým cukrom. Polovice jabĺk zbavíme jaderníka a nožom na šúpanie zemiakov nakrájame na čo najtenšie plátky. Tie poukladáme na pásy cesta a prekryjeme spodnou polovicou cesta. ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "81d19d9f-8cdc-47a2-acf8-f19cab9eefdf",
      "url": null,
      "text": "Plát zrolujeme a dáme na plech -  do košíčka (alebo formy na muffiny).",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "0c9d6ad8-93ab-4f6f-8eba-d1eee5caa042",
      "url": null,
      "text": "Pečieme 20-25 min pri 200 °C. Posypeme práškovým cukrom. Podávame teplé alebo aj studené.",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    }
