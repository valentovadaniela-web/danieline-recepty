  "instructions": [
    {
      "id": "935c7f17-a88c-4b95-a3ec-dedb33858cea",
      "url": null,
      "text": "Z okrúhleho chleba podľa formy (napr. pokrievky) vyrežeme tvar torty. ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "f0095211-0312-4d50-8669-246319ec4fc5",
      "url": null,
      "text": "Odrežeme aj vrchnú a spodnú časť chleba.",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "74d2fe30-67c0-4547-b82c-fb6acb7252b3",
      "url": null,
      "text": " Zostávajúcu mäkkú časť rozrežeme na pláty (podľa hrúbky; 4 až 6).",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "f0e92ef8-bed8-484e-873f-a93b3da05161",
      "url": null,
      "text": "Na spodný plát natrieme maslo a poukladáme naň šunku (alebo šunkový salám). ",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "f595eda0-3197-453a-8c28-419192b0f61b",
      "url": null,
      "text": "Pláty potierame maslom po oboch stranách. ",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    },
    {
      "id": "9bc7b0ac-d40a-4c05-b43b-f45911a5aced",
      "url": null,
      "text": "Na druhý plát dáme tenké rezy syra. ",
      "image_url": null,
      "sort_order": 5,
      "is_group_header": false
    },
    {
      "id": "71f5108a-62bd-4f04-95f5-cfebaa76c355",
      "url": null,
      "text": "Na tretí plát natrieme pečeňovú paštétu,",
      "image_url": null,
      "sort_order": 6,
      "is_group_header": false
    },
    {
      "id": "eb4c7a01-4450-4155-bb35-68bfa1a2348e",
      "url": null,
      "text": "Na štvrtý plát rozotrieme vykostené sardinky a pod. ",
      "image_url": null,
      "sort_order": 7,
      "is_group_header": false
    },
    {
      "id": "746c7286-2b24-4b01-8053-4735670ba84c",
      "url": null,
      "text": "Prikryjeme posledným plátom a mierne tortu stlačíme. ",
      "image_url": null,
      "sort_order": 8,
      "is_group_header": false
    },
    {
      "id": "810dc0f3-da40-4055-8cce-d55b880e441d",
      "url": null,
      "text": "Celú tortu potrieme pečeňovou paštétou, boky zasypeme strúhaným syrom a vrch ozdobíme podľa vkusu.",
      "image_url": null,
      "sort_order": 9,
      "is_group_header": false
    }
  ],
