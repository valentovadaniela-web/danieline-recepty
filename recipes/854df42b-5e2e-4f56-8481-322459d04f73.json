  "instructions": [
    {
      "id": "df691cb1-e911-4936-857d-598a6d30f95f",
      "url": null,
      "text": "Čerstvé výhonky smreka striedavo vrstvíme s kryšlálovým cukrom vo vysterilizovanom sklenom pohári. Prvá a posledná vrstva musí byť cukor.",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "29b88ca5-4ea2-41b1-b615-e264fafffc40",
      "url": null,
      "text": "Pohár necháme stáť cca 8 týždňov na slnku, napr. na okennom parapete. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "5d18c4ea-4db9-4097-9b9b-f47eb16b87ae",
      "url": null,
      "text": "Po 2 mesiacoch všetko precedíme cez gázu, (nesmie byť škrobená) a gázu vyžmýkame. ",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "3238b37a-0175-40f9-9b8f-94b34ce6f90d",
      "url": null,
      "text": "Sirup sa uskladňuje v chladničke. ",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "325626d1-b29d-45ac-8b11-5e9d991badf2",
      "url": null,
      "text": "Užíva sa kávová lyžička 3-5 x  denne.",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    }
  ],
