  "instructions": [
    {
      "id": "6d151811-61db-4964-973a-e3792685a497",
      "url": null,
      "text": "Zmiešame suroviny a dáme do pekárne - program Cesto (1:50). ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "97896ab2-b4ac-40fb-b15d-ff950f3c2ac9",
      "url": null,
      "text": "Po vykysnutí si kúsok cesta odložíme (na nohy a oči), zvyšok rozvaľkáme na obdĺžnik veľkosti plechu (1 cm hrubý), trochu zrežeme rohy, a po dlhších stranách narežeme šikmo radielkom. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "9991e67a-f954-41c8-b8ec-d38accadc588",
      "url": null,
      "text": "Doprostred položíme náplň a narezané pruhy cez seba na striedavo poskladáme. ",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "67361bf0-caa2-41fa-8ebb-2722e9e9656c",
      "url": null,
      "text": "Dáme na plech a dotvarujeme hlavu (okraje preložíme cez seba a rukou sploštíme), chvost stočíme. ",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "b988c888-efaf-4dce-83d5-d36408a91dc0",
      "url": null,
      "text": "Zo zvyšného cesta vytvarujeme nohy, narežeme prsty a vytvarujeme oči, do jamiek môžeme vložiť napríklad olivy. ",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    },
    {
      "id": "104f7a4a-eef3-4018-aac7-9a0bce6d5a4d",
      "url": null,
      "text": "Nožničkami nastriháme na papuli zuby a po tele ostne. ",
      "image_url": null,
      "sort_order": 5,
      "is_group_header": false
    },
    {
      "id": "8c120526-5a52-4370-ad2b-e7377f16cad9",
      "url": null,
      "text": "Potrieme rozšľahaným vajcom a pečieme v predhriatej rúre (200 °C, 30 min).",
      "image_url": null,
      "sort_order": 6,
      "is_group_header": false
    }
  ],
