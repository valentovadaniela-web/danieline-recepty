  "instructions": [
    {
      "id": "2122c80b-be73-4210-a316-451dacd962c5",
      "url": null,
      "text": "Mäso nakrájané na kocky, prudko opečieme na oleji a odstavíme. ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "874e394d-24fc-46b1-a66e-4de0bf45388e",
      "url": null,
      "text": "V druhej nádobe do ružova opražíme nadrobno nakrájanú cibuľu. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "7b976970-29fc-494f-a7f4-c0024a8596f8",
      "url": null,
      "text": "Pridáme rozotretý cesnak a mleté korenie. ",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "3cce4f71-186e-4539-a2d3-e460280de751",
      "url": null,
      "text": "Mäso osolíme, posypeme tymiánom, materinou dúškou a petržlenovou vňaťou. Pridáme 2 bobkové listy. Polovicu mäsa uložíme do jenskej misy a prikryjeme polovicou opraženej cibule. ",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "6a51f537-0498-4c68-859a-39875aacecaf",
      "url": null,
      "text": "Vrstvy zopakujeme. ",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    },
    {
      "id": "48b0815a-f7d6-4f76-9800-b86db35967de",
      "url": null,
      "text": "Podlejeme vývarom a pivom tak, aby mäso bolo prekryté tekutinou. ",
      "image_url": null,
      "sort_order": 5,
      "is_group_header": false
    },
    {
      "id": "f9155609-d88c-4e54-93af-a5066ea84c32",
      "url": null,
      "text": "Pridáme karamel rozpustený v troche vody. ",
      "image_url": null,
      "sort_order": 6,
      "is_group_header": false
    },
    {
      "id": "6541346f-eae2-4b4f-9aa1-c48c4f185d9c",
      "url": null,
      "text": "Prikryté dusíme v rúre do mäkka.",
      "image_url": null,
      "sort_order": 7,
      "is_group_header": false
    },
    {
      "id": "830e20ef-1f93-4651-9688-d6f240c2ac69",
      "url": null,
      "text": "Šťavu zlejeme a krátkym varením so Solamylom zahustíme a vlejeme naspäť k mäsu. Podávame so zemiakmi alebo ryžou.",
      "image_url": null,
      "sort_order": 8,
      "is_group_header": false
    }
  ],
