  "instructions": [
    {
      "id": "ce26323f-b1ec-4d73-8c8c-8d8d79b81cd1",
      "url": null,
      "text": "Maslo, žĺtky a 150 g práškového cukru vymiešame dohladka. Prisypeme múku s práškom do pečiva. Cesto vymiešame a ¼ cesta odložíme do mrazničky. Zostávajúcu časť cesta vyvaľkáme na veľkosť plechu najlepšie na papieri na pečenie. S ním ho preložíme na plech.",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "e9b25300-4c55-41da-88b7-a48bd6eaa9c2",
      "url": null,
      "text": "Očistené jablká nahrubo nastrúhame. Pridáme vopred namočené (môže byť v rume) a zmäknuté hrozienka, odkôstkované višne, orechy a vanilkový cukor. Jablkovú zmes premiešame a natrieme na cesto.",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "6d916124-6a4f-4b04-9a8e-16c35e00feff",
      "url": null,
      "text": "Zo 6 bielkov vyšľaháme tuhý sneh. pridáme 150 g práškového cukru a znovu vyšľaháme. Snehovú penu natrieme na jablkovú plnku.",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "435836b4-ff36-47f4-a212-3c7fbda424d9",
      "url": null,
      "text": "Odloženú ¼ cesta z mrazničky nahrubo nastrúhame na natretý sneh. Koláč upečieme (175 °C, 30 min).",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "622eb296-c741-46d5-8d65-4bc166624001",
      "url": null,
      "text": "Krájame až keď vychladne.",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    }
  ],
