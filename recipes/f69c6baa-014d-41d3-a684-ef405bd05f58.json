  "instructions": [
    {
      "id": "30fe9aca-c9ce-47e0-a0ff-18bb01549c4a",
      "url": null,
      "text": "Žĺtky vyšľaháme s 2/3 cukru do peny, pridáme vriacu vodu a vyšľaháme do husta. ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "187670fb-c563-47e7-8e47-a326917a4054",
      "url": null,
      "text": "Vmiešame olej. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "ae746ded-91f6-4231-b15c-d3fd356713f0",
      "url": null,
      "text": "Bielky napeníme do riedkej peny, vsypeme cukor a ušľaháme sneh. Sneh spojíme so žĺtkovou zmesou. ",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "3856e55a-8f45-4afc-b1ac-c35f01559c71",
      "url": null,
      "text": "Múku, prášok do pečiva a kakao preosejeme do zmesi a jemne spojíme. ",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "65898c11-acae-44a6-99c7-691f6443488f",
      "url": null,
      "text": "Pečieme pri 150°C. ",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    },
    {
      "id": "ece726ca-e327-45ea-ac10-ba49994d5feb",
      "url": null,
      "text": "Ošúpané jablká nastrúhame na hrubo, polejeme citrónovou šťavou, podlejeme asi 1-2 dcl vody a dusíme asi 10 min. ",
      "image_url": null,
      "sort_order": 5,
      "is_group_header": false
    },
    {
      "id": "1eddc9ae-b07b-46e9-b726-ab5c56fdf786",
      "url": null,
      "text": "V 3 dcl vody rozmiešame Zlatý klas, vlejeme do jabĺk a povaríme. Nakoniec pridáme škoricový cukor. Necháme chladnúť.",
      "image_url": null,
      "sort_order": 6,
      "is_group_header": false
    },
    {
      "id": "825695a3-422f-4a47-be79-e91ddc46e93f",
      "url": null,
      "text": "Na vychladnutý korpus nanesieme šľahačkovú vrstvu: Šľahačku vyšľaháme. Stužovač rozmiešame v 1 dcl vody a vlejeme do šľahačky, zmiešame, natrieme na korpus a dáme do chladu stuhnúť.",
      "image_url": null,
      "sort_order": 7,
      "is_group_header": false
    },
    {
      "id": "78db271e-e114-4669-ab25-8e232b13cc17",
      "url": null,
      "text": "Na stuhnuté vylejeme vlažnú jablkovú zmes, uhladíme a dáme do chladu. ",
      "image_url": null,
      "sort_order": 8,
      "is_group_header": false
    }
  ],
