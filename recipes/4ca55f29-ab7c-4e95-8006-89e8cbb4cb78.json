      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "5b180be4-b398-4747-8d55-0d6e76b061e1",
      "url": null,
      "text": "Zdobíme ovocím a nastrúhanou čokoládou.",
      "image_url": null,
