  "instructions": [
    {
      "id": "27431fb5-37e8-4278-a3ee-6ce61ec2e72c",
      "url": null,
      "text": "Vajcia s cukrom šľaháme nad parou približne 5–8 minút, kým zmes nezhustne a nedosiahne približne 70–75 °C. Potom necháme úplne vychladnúť.",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "24712ddb-76cb-4972-9e37-7ccbe4e996f2",
      "url": null,
      "text": "Po vychladnutí pridáme vaječný koňak a postupne zamiešame aj Mascarpone. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "bb786c40-c706-4530-a0c5-8998af3c1c9c",
      "url": null,
      "text": "Pripravíme silnú kávu, necháme ju vychladnúť a primiešame rum.",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "c4b28350-5dcc-49aa-9077-40d6437bd6a8",
      "url": null,
      "text": "Do vychladnutej kávy namáčame piškóty a uložíme ich do misy alebo tortovej formy, na to dáme vrstvu krému, opäť piškóty a znovu vrstvu krému (trochu viac). ",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "5748093a-c441-4dde-be4c-9158dd4be4cb",
      "url": null,
      "text": "Vrch posypeme kakaom (cez sitko). Necháme v chladničke aspoň 6 hodín (ideálne cez noc)",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    }
