  "instructions": [
    {
      "id": "8dbf1766-2668-4988-a5b8-56cd152b2199",
      "url": null,
      "text": "Vajcia, cukor a vanilkový cukor zmiešame. Pridáme olej, mlieko a múku s práškom. Upečieme (175 °C, cca 18 min).",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "5a049716-f70b-4f2c-84fd-d2aa0fc3160a",
      "url": null,
      "text": "Z džúsu, Zlatých klasov a cukru uvaríme hustý krém. Ešte teplý ho vylejeme na vychladnuté cesto a dáme do chladu. Potom naň natrieme dotuha vyšľahané šľahačky so stužovačom.",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "d7b143a3-fe8a-480f-8dfd-23952728d2ed",
      "url": null,
      "text": "Piškóty namáčame do džúsu s rumom a ukladáme tesne vedľa seba na šľahačku. Vrch ozdobíme roztopenou čokoládou. Rezy krájame pomedzi piškóty.",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    }
  ],
