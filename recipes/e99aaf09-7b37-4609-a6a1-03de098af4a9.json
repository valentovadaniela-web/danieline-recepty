  "instructions": [
    {
      "id": "94d55e18-71bf-4d83-99f1-87a210bee2fa",
      "url": null,
      "text": "Smotanu s cukrom a preosiatym kakaom necháme zovrieť. Odstavíme a vmiešame na kúsky polámanú čokoládu. Necháme v chlade stuhnúť.",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "5894f4a8-292e-464e-b6b1-ada194938352",
      "url": null,
      "text": "Vyšľaháme šľahačku do polotuha. Vymiešame vajcia, cukor a vanilkový cukor do peny a pridáme šľahačku. Vmiešame orechy a polámanú čokoládu a múku s práškom do pečiva. Vylejeme do vymastenej a hrubou múkou vysypanej formy. Pečieme  hodinu pri 150 °C. Necháme krátko vychladnúť a vyklopíme. Studenú vodorovne 2x prekrojíme na tri časti.",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "e57945a8-1177-4d97-b8d6-ac860c004914",
      "url": null,
      "text": "Stuhnutý krém vyšľaháme a bábovku zlepíme krémom do pôvodného tvaru. Nakoniec bábovku polejeme čokoládou alebo čokoládovou polevou a necháme v chladničke stuhnúť.",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    }
  ],
