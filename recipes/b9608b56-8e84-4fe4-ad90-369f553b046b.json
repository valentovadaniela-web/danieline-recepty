  "instructions": [
    {
      "id": "c7004bec-9049-450e-a244-0d9525da6e99",
      "url": null,
      "text": "Z múky, tuku, 1 lyžičky soli, 60 g postrúhaného syra a z kvásku zamiesime cesto. Sformujeme ho do valca a rozrežeme na 6 dielov. Každý diel postupne rozvaľkáme na okrúhlu placku a tú rozrežeme radielkom na 16 dielov. Každý diel od širšieho konca zvinieme. ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "282125a2-64d2-4506-af23-0202870b3c34",
      "url": null,
      "text": "Závitky uložíme na suchý plech, potrieme ich rozmiešaným vajcom a posypeme zvyškom strúhaného syra s lyžičkou soli. Upečieme do ružova (200 °C, 15 min).",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    }
