  "instructions": [
    {
      "id": "0e177aad-143a-4331-9d2d-641ecdde4cad",
      "url": null,
      "text": "6 žĺtkov + 18 dkg práškového cukru vymiešame do peny. Pridáme múku s práškom do pečiva a sneh z bielkov. Upečieme (pri 175°C – 15-20 min). Na vychladnutý korpus natrieme lekvár.",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "e459db26-ed54-4824-b369-c77af8d4aea6",
      "url": null,
      "text": "Marhule vyberieme z kompótu, necháme odkvapkať, trochu osušíme servítkou a poukladáme na papier na pečenie. Cikcakovito polejeme roztopenou čokoládou. Zo zvyšnej čokolády nakvapkáme na papier ešte cca 35 asi 1 cm koliesok, na ktoré, po miernom stuhnutí, bielou čokoládou (alebo bielymi ozdobnými cukríkmi) urobíme oči. Pomocou noža narežeme na chrbte 2 ryhy a tam šikmo zasunieme 2 mandľové lupienky.",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "0fcbe994-374d-419e-abc1-a52fc6b57be1",
      "url": null,
      "text": "2 kyslé smotany, vanilkový cukor a vyšľahanú šľahačku zmiešame a natrieme na korpus potretý lekvárom.",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "f2ab40a3-7add-44b4-b310-981cef379d3f",
      "url": null,
      "text": "600 ml šťavy z kompótu, Zlatý klas a 100 g práškového cukru uvaríme na hustú kašu a polovychladnutú nalejeme na koláč.",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "090668b6-c5c9-47a1-9893-ea2c64bb4208",
      "url": null,
      "text": "Na želatínu poukladáme včielky. Koláč necháme minimálne 1 hodinu (lepšie cez noc) v chlade.",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    }
  ],
