  "instructions": [
    {
      "id": "cb9ab59f-13c7-4bf4-b518-57490f6d7e6b",
      "url": null,
      "text": "Na oleji opražíme pretlačený cesnak a hladkú múku (cca 2 PL). ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "add42cac-d269-4175-afe2-b9d9a99c42ff",
      "url": null,
      "text": "V nádobe zmiešame smotanu a 2 PL hladkej múky ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "77857236-427f-4319-ad45-593d23295179",
      "url": null,
      "text": "Pridáme cesnakovú zápražku a nalejeme do hrnca. ",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "237ea10f-23c1-482d-bc21-26259cd9ecf5",
      "url": null,
      "text": "Šalát nakrájame alebo natrháme na menšie kúsky a pridáme do hrnca. ",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "6d430798-4807-4565-ae7a-2e693c071bac",
      "url": null,
      "text": "Osolíme, pridáme ČL cukru, trochu masla a uvaríme.",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    },
    {
      "id": "3c6ab7cc-68d2-4765-9da5-e0698671b92c",
      "url": null,
      "text": "Podávame s varenými vajíčkami.",
      "image_url": null,
      "sort_order": 5,
      "is_group_header": false
    }
  ],
