  "instructions": [
    {
      "id": "828e750e-cd0e-4917-892a-33d5a8e19c19",
      "url": null,
      "text": "Vajcia vyšľaháme s cukrom a horúcou vodou do hustej peny. Postupne vmiešame múku zmiešanú so škoricou, kakaom a práškom do pečiva. Cesto vylejeme do tortovej formy vystlanej papierom na pečenie a pečieme pri 180 °C približne 20 minút. Po vychladnutí korpus rozrežeme na dve polovice (vodorovne).",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "8a2a9371-b295-444e-a0bb-7b100e969c64",
      "url": null,
      "text": "Spodný plát pokropíme rumom, natrieme marhuľovým džemom a prikryjeme druhým plátom, ktorý takisto zľahka pokropíme rumom. Okolo korpusu upevníme tortovú obruč.",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "cbe988c6-a78e-4e97-ae77-540c6fa3e878",
      "url": null,
      "text": "Želatínu zalejeme pomarančovou šťavou a necháme napučať. Potom ju v kastróliku pri nízkej teplote rozpustíme (nesmie vrieť!). Necháme mierne vychladnúť.",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "8ab2c519-076c-483f-8912-bbb6b703244e",
      "url": null,
      "text": "Smotanu na šľahanie vyšľaháme dotuha (môžete pridať stužovač).",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "bf4ebbf1-a67a-4ca6-a91a-61d1b3c37015",
      "url": null,
      "text": "V miske zmiešame kyslú smotanu s vanilkovým cukrom a pomarančovou kôrou.",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    },
    {
      "id": "9079e606-922b-474d-9b01-7255ad1fcdc8",
      "url": null,
      "text": "Do zmesi kyslej smotany zašľaháme vlažnú želatínu a nakoniec vareškou opatrne vmiešame vyšľahanú šľahačku.",
      "image_url": null,
      "sort_order": 5,
      "is_group_header": false
    },
    {
      "id": "dddd922d-5da2-4e3a-8e3e-c4fd85557ded",
      "url": null,
      "text": "Krém vylejeme na korpus v obruči a dáme do chladničky stuhnúť minimálne na 8 hodín.",
      "image_url": null,
      "sort_order": 6,
      "is_group_header": false
    },
    {
      "id": "8c63284b-9f39-415c-9107-5f1428c351f9",
      "url": null,
      "text": "Po stuhnutí odstránime obruč. Tortu rozrežeme na polovicu.",
      "image_url": null,
      "sort_order": 7,
      "is_group_header": false
    },
    {
      "id": "5e0f7eff-d4a8-4a7b-9e27-66ba68f15697",
      "url": null,
      "text": "Dve polovice položíme na podnos oblými stranami k sebe tak, aby vytvorili krídla motýľa.",
      "image_url": null,
      "sort_order": 8,
      "is_group_header": false
    },
    {
      "id": "8e263755-80df-4fb3-a7fc-a379c59a9736",
      "url": null,
      "text": "Povrch krídel jemne posypeme farebným kokosom.",
      "image_url": null,
      "sort_order": 9,
      "is_group_header": false
    },
    {
      "id": "228271dd-4a40-4a05-b2d8-56db27927e38",
      "url": null,
      "text": "Pomocou zdobiaceho vrecúška vytvoríme zo šľahačky pásy na okrajoch krídel (ako na obrázku).",
      "image_url": null,
      "sort_order": 10,
      "is_group_header": false
    },
    {
      "id": "ea0de542-b31b-4654-aa37-e780eadcae8b",
      "url": null,
      "text": "Do šľahačkových pásov ukladáme kúsky farebného ovocného želé.",
      "image_url": null,
      "sort_order": 11,
      "is_group_header": false
    },
    {
      "id": "ec681b7c-d54a-4c4b-8b06-3ae39c93d362",
      "url": null,
      "text": "V strede medzi krídlami vytvoríme zo šľahačky „telíčko“ motýľa.",
      "image_url": null,
      "sort_order": 12,
      "is_group_header": false
    },
    {
      "id": "bf790299-05ec-4cea-9bd4-1ed952a810dc",
      "url": null,
      "text": "Na vrch telíčka zapichneme dve trubičky ako tykadlá a môžeme pridať čokoládové bodky (napr. z kúskov čokolády) ako oči.",
      "image_url": null,
      "sort_order": 13,
      "is_group_header": false
    }
  ],
