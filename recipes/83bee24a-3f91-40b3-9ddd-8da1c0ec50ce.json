    {
      "id": "ae1bdbca-dca4-4e0c-b65c-e48ec9259d6b",
      "url": null,
      "text": "Pridáme olej, vaječný koňak a múku so Solamylom a práškom do pečiva. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "a99f0bc9-88aa-4541-a4f3-5b33bed73f62",
      "url": null,
      "text": "Z bielkov a 100 (150*)g cukru vyšľaháme sneh. Opatrne zmiešame so žĺtkovým krémom.",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "7fbae549-e3ba-43b8-8aca-007c14d6217a",
      "url": null,
      "text": " Do ¼ cesta primiešame kakao alebo Nutellu. ",
