  "instructions": [
    {
      "id": "abb199ae-12c6-4d6c-902f-ec670bb323d2",
      "url": null,
      "text": "Rezne naklepeme, osolíme, okoreníme a obalíme v múke. ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "fba33b09-5180-406f-9f6b-f0dff247d907",
      "url": null,
      "text": "Cibuľu nakrájame na tenké kolieska a udusíme do sklovita. Potom ju rozložíme na dno pekáča. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "f328b41e-5d4d-4f64-907b-76703c4eb7d1",
      "url": null,
      "text": "Na cibuľu uložíme rezne. ",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "cb07d9b4-0af2-4236-8773-c1247f37b014",
      "url": null,
      "text": "Nahrubo nastrúhaný syr zmiešame so žemľovými omrvinkami a posekanou pažítkou a navrstvíme na rezne. ",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "c78957e9-86ed-498f-a65e-a4a0aa123358",
      "url": null,
      "text": "Polejeme vínom, maslom a vývarom. ",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    },
    {
      "id": "5a1858ee-c6c4-4933-bf7d-dedd737d1af9",
      "url": null,
      "text": "Navrch rozložíme šampiňóny (ak sú malé, môžu byť aj celé) a polejeme smotanou. ",
      "image_url": null,
      "sort_order": 5,
      "is_group_header": false
    },
    {
      "id": "75e0ee3e-1e96-45e7-b9a9-500827720c41",
      "url": null,
      "text": "V horúcej rúre pečieme asi 40 minút.",
      "image_url": null,
      "sort_order": 6,
      "is_group_header": false
    }
  ],
