  "instructions": [
    {
      "id": "6a55028b-efda-4461-9695-06affe362f28",
      "url": null,
      "text": "Zmiešame suroviny a masu vyvaľkáme medzi 2 papiermi na pečenie na hrúbku 1,5 cm. ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "4068c4ef-45ee-4e74-b61f-0baa99863547",
      "url": null,
      "text": "Dáme zachladiť na 10 min do mrazničky. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "b94ea698-a90e-47c7-a419-fe4dfe3acc18",
      "url": null,
      "text": "Vykrajujeme formičkou na jazýčky a opäť vrátime do mrazničky na 10 minút. ",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "bf5fcb12-76ca-4ce2-82a8-f773aea7faee",
      "url": null,
      "text": "Čokoládu s Cerou rozpustíme nad parou. Keď je čokoláda vlažná, obaľujeme v nej jazýčky pomocou vidličky. Čokoládové jazýčky kladieme na pečiaci papier a dáme do chladu stuhnúť.",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "d27048a8-6e60-4145-9fe8-6fc504050fa1",
      "url": null,
      "text": "Podávame so šľahačkou",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    }
