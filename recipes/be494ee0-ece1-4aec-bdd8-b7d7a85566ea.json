  "instructions": [
    {
      "id": "50bf1afe-f4d0-49dc-90bf-963c1801d62b",
      "url": null,
      "text": "Mlieko + Zlatý klas uvariť dohusta a nechať vychladnúť. Maslo + cukor + žĺtok + rum vymiešať. Postupne pridávať studený puding a vymiešať dohladka. Do ½ hmoty pridať kakao. ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "cae72fec-08b5-4c57-b1a7-f504cffd503f",
      "url": null,
      "text": "Krém natierať na keksy a striedavo ukladať žltú a kakaovú vrstvu. Nakoniec potrieť kakaovým krémom zo všetkých strán a posypať kokosovou múčkou alebo mletými orechmi. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "01cf2932-7928-4074-b512-be0d670081fa",
      "url": null,
      "text": "Zabaliť do alobalu a nechať aspoň 12 hodín stáť v chlade.",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "9cf2c1f4-0821-46eb-be45-fa1d56141628",
      "url": null,
      "text": "Krájať šikmo.",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    }
