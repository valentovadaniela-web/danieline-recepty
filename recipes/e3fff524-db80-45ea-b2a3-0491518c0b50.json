  "instructions": [
    {
      "id": "47799969-d485-4b71-abcb-bad71efa86fe",
      "url": null,
      "text": "Droždie rozmrvíme do veľkej misy a rozpustíme ho v troche teplej vody. ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "fb85128f-698d-4294-b7ac-b063d4971ea0",
      "url": null,
      "text": "Pridáme soľ, rascu, olej a ocot, prípadne semienka. Zmiešame a vsypeme kilo múky. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "5c3fef46-7ca6-486a-8633-c3fddd283be7",
      "url": null,
      "text": "Postupne pridávame teplú vodu a miesime. Správne tuhé cesto má pevnú konzistenciu a nerozteká sa v ruke. ",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "bb2a3dae-d463-45a9-95d7-c0e3dc7fa301",
      "url": null,
      "text": "Necháme zakryté vykysnúť na teplom mieste cca 1 - 1,5 hod. ",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "f7c5010c-6a34-456f-ab31-dc8e86eb49b6",
      "url": null,
      "text": "Potom vyklopíme do jenskej misy s vystrihnutýmj papierom na pečenie na dne (prípadne na plechu vystlanom papierom na pečenie vytvarujeme bochník). ",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    },
    {
      "id": "feb55236-bc4a-4548-8449-dfa21d81e1b2",
      "url": null,
      "text": "Popicháme vidličkou. ",
      "image_url": null,
      "sort_order": 5,
      "is_group_header": false
    },
    {
      "id": "36ec0adc-3ae5-46a4-b95a-70e4d85856d7",
      "url": null,
      "text": "Potrieme slanou vodou (2 dcl vody a ½ ČL soli) a môžeme posypať semienkami. ",
      "image_url": null,
      "sort_order": 6,
      "is_group_header": false
    },
    {
      "id": "390a098e-03b0-4441-aa1d-b34c9ab8d2e4",
      "url": null,
      "text": "Pečieme vo vyhriatej rúre 1/2 hod pri 210°C. ",
      "image_url": null,
      "sort_order": 7,
      "is_group_header": false
    },
    {
      "id": "53508a0d-d640-44ce-9f95-44c6e132dbea",
      "url": null,
      "text": "Potom potrieme slanou vodou a ďalšiu polhodinu pečieme pri 160°C). ",
      "image_url": null,
      "sort_order": 8,
      "is_group_header": false
    },
    {
      "id": "24abd5d7-2ba3-49d9-817d-5e8b303b7538",
      "url": null,
      "text": "Upečený chlieb má po poklopaní znieť duto. ",
      "image_url": null,
      "sort_order": 9,
      "is_group_header": false
    },
    {
      "id": "933531c1-3c60-4ac3-a7ab-942ce89280ae",
      "url": null,
      "text": "Chlieb potrieme tretíkrát slanou vodou a necháme chladnúť prikrytý na mriežke.",
      "image_url": null,
      "sort_order": 10,
      "is_group_header": false
    }
  ],
