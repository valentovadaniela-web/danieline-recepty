  "instructions": [
    {
      "id": "b615bfc9-0bee-4e07-8c93-19ac0e4f053c",
      "url": null,
      "text": "Lístkové cesto rozvaľkáme. Na cesto rozotrieme mäkký syr. Rozložíme plátky šunky a tvrdého syra. posypeme vegetou a pevne zakrútime do rolky. Naplnenú rolku dáme do alobalu a odložíme aspoň na 2 hodiny do chladničky.",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "8cbf2785-7a2c-47c0-b229-ac28d140f70f",
      "url": null,
      "text": "Potom alobal odstránime a rolku nakrájame na kolieska. Ukladáme na vymastený plech, potrieme žĺtkom, posypeme tymiánom a dáme piecť do vyhriatej rúry (175 °C, cca 12 - 15 min). ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    }
