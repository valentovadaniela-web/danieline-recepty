  "instructions": [
    {
      "id": "a864ae56-6720-48e9-95fd-c7ade821990a",
      "url": null,
      "text": "Šošovicu opláchneme, zalejeme studenou vodou tak 2 cm nad šošovicou a necháme namočenú 2 hodiny alebo aj celú noc. ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "95bda2c2-1a59-48f6-b020-8ade334d2245",
      "url": null,
      "text": "Šošovicu varíme v tej istej vode spolu s bobkovým listom, celou cibuľou a čiernym korením. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "1038654d-1342-49b0-92b5-0c8bebba84ad",
      "url": null,
      "text": "Šošovicu solíme až po uvarení, inak by nezmäkla. ",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "248e695d-2c9b-47d4-ac3d-edc56da9f941",
      "url": null,
      "text": "Pred dovarením pridáme očistené a na kocky pokrájané zemiaky. ",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "a2a8c4f8-11bf-4877-8b39-b503f688424b",
      "url": null,
      "text": "Vymiešame smotanu spolu s 1 PL múky tak, aby v nej neostali žiadne hrudky a prilejeme k prívarku. ",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    },
    {
      "id": "c1a7b3fd-22d9-4ad5-b692-3744c8a5465d",
      "url": null,
      "text": "Pridáme trochu masla a cukru. ",
      "image_url": null,
      "sort_order": 5,
      "is_group_header": false
    },
    {
      "id": "8d2ec325-8b91-42c9-b1e2-9147ac656c57",
      "url": null,
      "text": "Dochutíme horčicou a znovu prevaríme.",
      "image_url": null,
      "sort_order": 6,
      "is_group_header": false
    }
  ],
