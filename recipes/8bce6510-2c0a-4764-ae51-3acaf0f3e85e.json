  "instructions": [
    {
      "id": "2fa73cd3-2a59-43e2-8288-f044e9c330f7",
      "url": null,
      "text": "Upálime na karamel toľko lyžíc cukru, koľko máme dcl vodky. Pridáme niekoľko klinčekov, kúsok škorice, asi ½ vlašského orecha, kúsok kandizovanej pomarančovej kôry, kúsok vanilky.",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "16a8b1f9-429c-4244-abdc-312e1c829f78",
      "url": null,
      "text": "Zalejeme polovičným množstvom vody (t.j. na ½ l vodky  ¼ l vody). Keď sa karamel rozpustí a voda zovrie, opatrne prilejeme vodku. Keď začne vrieť, odstavíme a prikryjeme.",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "62290528-2eae-4832-9645-03201a1c1294",
      "url": null,
      "text": "Počkáme, kým sa koreniny usadia a prelejeme. Pijeme teplé alebo studené",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    }
  ],
