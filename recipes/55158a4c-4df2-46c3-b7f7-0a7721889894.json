  "instructions": [
    {
      "id": "b92e869a-4f06-4c33-8157-3b115afa0264",
      "url": null,
      "text": "Suroviny a kvások zamiesime na redšie cesto a necháme vykysnúť na teplom mieste. ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "e0c2beb5-89a8-4b00-b779-a57d9aacdc23",
      "url": null,
      "text": "Dáme na pomúčenú dosku a rozvaľkáme na hrúbku prsta. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "d081c415-414d-4f62-b368-7d5f6daff2ff",
      "url": null,
      "text": "Na cesto postrúhame varené zemiaky, na ne postrúhame Heru a 3x preložíme. Necháme 20 min odpočívať. Potom ešte 2x preložíme. ",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "db5c6e6d-bea5-495f-908a-317886502d35",
      "url": null,
      "text": "Rozvaľkáme, vykrojíme pagáčiky, potrieme ich žĺtkom a môžeme posypať sézamom alebo rascou. ",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "3b78c71e-0506-4a02-9686-ea0cf09e9b56",
      "url": null,
      "text": "Upečieme 40 min pri 180-200°C)",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    }
  ],
