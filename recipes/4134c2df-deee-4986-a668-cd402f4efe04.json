    },
    {
      "id": "f83cae75-cdf7-4259-9df3-918a3a8fb080",
      "url": null,
      "text": "Pridáme na kúsky nakrájanú rybu, osolíme, zalejeme malým množstvom vody a udusíme domäkka. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "304f35be-73c7-4005-89a9-595bc6a3f7a7",
      "url": null,
      "text": "Prisypeme čili (podľa chuti, aj 2 PL ak má byť paprikáš štipľavý). ",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "39e18640-0516-487d-b812-88917269b79d",
      "url": null,
      "text": "Po prevretí dolejeme šľahačku a necháme paprikáš znovu prevrieť.",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "8ae7c708-82e3-402d-ac3b-94055f0317db",
      "url": null,
      "text": "Podávame s čerstvým chlebom.",
