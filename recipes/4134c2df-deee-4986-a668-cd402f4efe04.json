  "instructions": [
    {
      "id": "1e4a0f64-69d1-4156-a450-dd081fd03038",
      "url": null,
      "text": "Nadrobno nakrájanú cibuľu speníme na masti, poprášime sladkou paprikou a len chvíľku popražíme. ",
      "image_url": null,
      "sort_order": 0,
