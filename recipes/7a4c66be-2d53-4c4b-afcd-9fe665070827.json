  "instructions": [
    {
      "id": "c1c83643-62f2-4f3e-9bb3-f49eb3105920",
      "url": null,
      "text": "Veterníky:",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": true
    },
    {
      "id": "f65b5355-3afd-4dc9-a558-2fae98b36fe8",
      "url": null,
      "text": "Do hrnca dáme 250 ml vody + 250 ml mlieka + 200 g masla + 10 g cukru + štipku soli. Zohrejeme na 100 °C (var).",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "5b361671-fce6-4a4f-bf96-98f7b96be753",
      "url": null,
      "text": "Prisypeme 300 g hladkej múky naraz.",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "fc17cd15-129e-46ac-b928-cc1fcd7dd845",
      "url": null,
      "text": "Miešame 2–3 min, kým sa cesto oddeľuje od hrnca. Cesto „osmažíme“ na dne (tenký film).",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "c86047b0-4f7e-4061-bc7b-bff120d24060",
      "url": null,
      "text": "Presunieme cesto do robota. Ochladíme na cca 45 °C (vlažné na dotyk).",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    },
    {
      "id": "66d3c078-dc86-45e2-a09f-020fa3bcb144",
      "url": null,
      "text": "Pridáme 8–10 vajec (450–500 g) po jednom. Každé vajce zapracujeme až do úplného spojenia. Správna konzistencia je, ak cesto padá zo stierky v „V tvare“, drží špičku, nerozteká sa. Jeden kus 6,5 - 7 cm, rozostupy cca 6 cm.",
      "image_url": null,
      "sort_order": 5,
      "is_group_header": false
    },
    {
      "id": "af58b588-12bb-4c80-b4cb-22256bf0a5be",
      "url": null,
      "text": "Pečieme 10 min pri 200 °C (nárast), potom 20–25 min pri 180–190 °C (dosušenie). Neotvárať rúru prvých 20 min. Veterník musí byť zlatohnedý a suchý. Dosušiť v pootvorenej rúre 5–10 min. Vyberieme na mriežku.",
      "image_url": null,
      "sort_order": 6,
      "is_group_header": false
    },
    {
      "id": "d8397168-ab76-45b9-b6e8-ed9cbe0f3a05",
      "url": null,
      "text": "VANILKOVÝ DIPLOMAT KRÉM (môžeme robiť paralelne s cestom)",
      "image_url": null,
      "sort_order": 7,
      "is_group_header": false
    },
    {
      "id": "0156b7f7-74f3-4bc4-a3a0-1dea156fb209",
      "url": null,
      "text": "Uvaríme krém z 600 ml mlieka + 120 g cukru + 60 g škrobu + 6 žĺtkov.",
      "image_url": null,
      "sort_order": 8,
      "is_group_header": false
    },
    {
      "id": "7e17ff1c-ddac-4a1e-8a8e-c9c6fd5b159e",
      "url": null,
      "text": "Zakryjeme fóliou a ochladíme na 4–6 °C.",
      "image_url": null,
      "sort_order": 9,
      "is_group_header": false
    },
    {
      "id": "6c70b2e1-ccae-4b02-881e-05f4bc587b98",
      "url": null,
      "text": "Vymiešame 100 g masla do peny.",
      "image_url": null,
      "sort_order": 10,
      "is_group_header": false
    },
    {
      "id": "15977a52-3503-49c6-a5c6-220008a94c85",
      "url": null,
      "text": "Zapracujeme puding do masla. Hmoty musia mať rovnakú teplotu.",
      "image_url": null,
      "sort_order": 11,
      "is_group_header": false
    },
    {
      "id": "f659c54b-a647-4b9f-97a6-187ef5d7b92d",
      "url": null,
      "text": "Vyšľaháme 400 ml smotany do mäkkých špičiek. Jemne ju zapracujeme.",
      "image_url": null,
      "sort_order": 12,
      "is_group_header": false
    },
    {
      "id": "48f93daa-41fc-4d29-b841-5963780c65d2",
      "url": null,
      "text": "KARAMELOVÁ ŠĽAHAČKA (môžeme robiť paralelne s krémom)",
      "image_url": null,
      "sort_order": 13,
      "is_group_header": false
    },
    {
      "id": "9c2eff00-eb62-48f0-901f-da7f3f3077ff",
      "url": null,
      "text": "Upálime 120 g cukru na svetlý karamel.",
      "image_url": null,
      "sort_order": 14,
      "is_group_header": false
    },
    {
      "id": "e2942a01-7aad-415b-ae5d-ef6989b134a5",
      "url": null,
      "text": "Zalejeme 200 ml horúcej smotany.",
      "image_url": null,
      "sort_order": 15,
      "is_group_header": false
    },
    {
      "id": "b43c916f-3779-416e-a1b7-139c230967b4",
      "url": null,
      "text": "Miešame do hladka.",
      "image_url": null,
      "sort_order": 16,
      "is_group_header": false
    },
    {
      "id": "86b3dd60-5b20-49ce-b7f2-1b0426ee3a8f",
      "url": null,
      "text": "Ochladíme minimálne 1–2 hod (ideálne 12 h).",
      "image_url": null,
      "sort_order": 17,
      "is_group_header": false
    },
    {
      "id": "02d57fad-7f9f-434e-922a-8cc469cb6c3f",
      "url": null,
      "text": "Vyšľaháme 500 ml smotany.",
      "image_url": null,
      "sort_order": 18,
      "is_group_header": false
    },
    {
      "id": "cf2401db-4b28-412d-8ab6-e0924f8e1596",
      "url": null,
      "text": "Zapracujeme karamel do pevnej peny.",
      "image_url": null,
      "sort_order": 19,
      "is_group_header": false
    },
    {
      "id": "5726ac77-5472-4061-bb01-020e6a8b32c6",
      "url": null,
      "text": "Rozkrojíme veterníky vodorovne.",
      "image_url": null,
      "sort_order": 20,
      "is_group_header": false
    },
    {
      "id": "c415c5b5-58e7-44e9-a8ba-5521ae852cfd",
      "url": null,
      "text": "Striekame žĺtkový krém (cca 25–30 g / ks), naňho karamelovú šľahačku (cca 20–25 g / ks).",
      "image_url": null,
      "sort_order": 21,
      "is_group_header": false
    },
    {
      "id": "c8cf7010-1c28-4b32-add5-68070b6a87e4",
      "url": null,
      "text": "FONDÁNOVÁ KARAMELOVÁ POLEVA",
      "image_url": null,
      "sort_order": 22,
      "is_group_header": false
    },
    {
      "id": "f2f65640-06a1-4f05-8074-b1fc0b602b19",
      "url": null,
      "text": "Upálime karamel, zalejeme smotanou, zmiešame s maslom.",
      "image_url": null,
      "sort_order": 23,
      "is_group_header": false
    },
    {
      "id": "b943baa9-4858-4e82-925c-678459cc37cf",
      "url": null,
      "text": "Fondán zahrejeme na 40–45 °C.",
