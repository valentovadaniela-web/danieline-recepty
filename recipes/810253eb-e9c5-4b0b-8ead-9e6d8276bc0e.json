  "instructions": [
    {
      "id": "44edd0ad-be22-4d35-9bdf-2606bebb097c",
      "url": null,
      "text": "Zmiešame hladkú múku, polohrubú múku, soľ, cukor a namrvené kvasnice. ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "aa921d2f-f704-45c2-8ebf-d298d324da92",
      "url": null,
      "text": "Prilejeme olej a vodu a vymiesime, kým sa cesto neoddeľuje z rúk. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "45d6280c-0e06-47b3-9a88-271ea96530c2",
      "url": null,
      "text": "Cesto necháme odležať deň alebo minimálne 6 hod v chladničke (dá sa použiť aj hneď, ale s odstátím je lepšie).",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "6b09580d-9e2d-4462-bc5b-7292169d4d8f",
      "url": null,
      "text": "Ručne vytiahneme tenké cesto (1 dávka = 4 pizze). ",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "f9eae50c-7462-449d-a681-db9afb598a18",
      "url": null,
      "text": "Do kečupu zamiešame  roztlačený cesnak, bazalku, oregano a tymian. Natrieme na celú pizzu až po okraje. Naukladáme prísady podľa chuti a posypeme syrom.",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    },
    {
      "id": "ba47a739-1b98-4eaf-89a4-5a821e50ad6b",
      "url": null,
      "text": "Pečieme v predhriatej rúre 10 minút pri 250°C (hore: 3. lišta odspodu, teplovzdušný ohrev hore+dole).",
      "image_url": null,
      "sort_order": 5,
      "is_group_header": false
    }
  ],
