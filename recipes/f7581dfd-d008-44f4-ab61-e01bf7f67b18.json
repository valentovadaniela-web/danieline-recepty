  "instructions": [
    {
      "id": "1b03c937-66cb-4398-b1fc-654afd5bf0a1",
      "url": null,
      "text": "Vyšľaháme cukor s vajcami, primiešame múku a kakao. Cesto rovnomerne rozotrieme na plech (na papier na pečenie) a upečieme (175°C, 15 min).",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "2d3d4ce0-d64b-4fe3-826b-3da497dd2bec",
      "url": null,
      "text": "40 g želatíny necháme cca 10 min napučať v 800 ml vody, potom pridáme 450 g cukru a dáme variť (necháme prevrieť). Želatínu necháme vychladnúť (1-1,5 hod).",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "0827afa8-ade6-4caf-b01e-89bcab63433d",
      "url": null,
      "text": "Vyšľaháme 2 šľahačky, pridáme do nich mleté orechy a polovicu (cca 0,5 l) chladného želatínového nálevu. Rozmiešame a vylejeme na upečené cesto (bude to tekuté, je potrebné cesto dookola utesniť, napr. alobalom). Necháme stuhnúť cca 30 min.",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "952d02a5-acfe-4257-b4bc-ad44dee12574",
      "url": null,
      "text": "Vyšľaháme dve šľahačky s trochou kakaa. Pridáme druhú polovicu želatínového nálevu a vylejeme na prvú stuhnutú vrstvu. Necháme dobre stuhnúť.",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    }
  ],
