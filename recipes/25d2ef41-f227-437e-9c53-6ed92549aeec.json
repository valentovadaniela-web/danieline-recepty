  "instructions": [
    {
      "id": "df531a9b-3b33-420b-9bb7-15af512b117e",
      "url": null,
      "text": "Očistenú mrkvu nastrúhame na široké slížiky a podusíme na masle domäkka. ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "b86135f1-d267-4126-8805-c738681283ce",
      "url": null,
      "text": "Pridáme kari a zalejeme vodou. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "28cb0e02-0574-4992-afc6-87a73883020f",
      "url": null,
      "text": "Potom pridáme kocku zeleninového vývaru a chvíľku povaríme.",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "2812ed37-c31e-4f21-a504-9fab6efc85ca",
      "url": null,
      "text": "Keď je mrkva mäkká prestaneme variť. Polievku dochutíme soľou, bielym korením a nakoniec prilejeme koňak. ",
