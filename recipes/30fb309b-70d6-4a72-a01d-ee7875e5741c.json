  "instructions": [
    {
      "id": "9bc1b330-5421-4506-b08b-5f14d3758f4d",
      "url": null,
      "text": "Z lístkového cesta vyvaľkať 2 tenké pláty a upiecť na opačnej strane plechov (250°C - 10 min, po 6–7 min vymeniť plechy). Pred pečením poprepichovať cesto.",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "2b27f5d6-707b-44c0-8863-986a3554394f",
      "url": null,
      "text": "8 dcl mlieka a 150 g cukru nechať variť. Do 2 dcl mlieka zamiešať maizeinu, hladkú múku, žĺtky a vanilkový cukor. Pridať k variacemu sa mlieku s cukrom. Uvariť na hustý krém. Ešte do horúceho zľahka zamiešať sneh z bielkov a 2 lyžíc kryštálového cukru. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "7eac684c-b380-425e-b282-dce809ef5888",
      "url": null,
      "text": "Napoly vychladnutý krém naniesť na 1 plát cesta. Po vychladnutí naniesť na krém vyšľahanú šľahačku. ",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "198431ee-1506-4b32-9315-4eeecdb00691",
      "url": null,
      "text": "Druhý plát poliať čokoládovou polevou, nakrájať na štvorce a po jednom ukladať na šľahačkovú vrstvu.",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "782249dd-fd97-47f5-8021-7b4384a816c8",
      "url": null,
      "text": "Nechať jeden deň stáť v chlade.",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    }
  ],
