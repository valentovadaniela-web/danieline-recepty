  "instructions": [
    {
      "id": "4e05197c-8b7b-492d-b889-349249da638f",
      "url": null,
      "text": "Do vlažného mlieka (cca 200 ml) dáme droždie, cukor a trochu hrubej múky a necháme na teplom mieste vykysnúť.",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "91970488-b3e7-4f62-8843-1e8b7d55aede",
      "url": null,
      "text": "Pridáme zvyšné mlieko, múku s práškom do pečiva, soľ, rozpustené maslo, zvyšok mlieka a vypracujeme hladké cesto. Na teplom mieste necháme vykysnúť a rozdelíme na 2 časti. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "3f75c081-91ca-4917-9e06-3270c9fed2ed",
      "url": null,
      "text": "Každú vyvaľkáme (do 1 cm), natrieť na to vymiešanú plnku a zrolujeme. Závin krájame na 1 cm rezy, ktoré ukladáme na vymastený plech. Necháme ešte raz vykysnúť a potrieme ich vodou.",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "0b4b9d52-f849-448e-b935-2acf1f4212db",
      "url": null,
      "text": " Pečieme v dobre vyhriatej rúre (230 °C – 10 min.)",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    }
  ],
