  "instructions": [
    {
      "id": "7093dca7-0726-42c5-a40c-eb5f34704dc6",
      "url": null,
      "text": "Z lístkového cesta vyvaľkať 2 tenké pláty a upiecť na opačnej strane plechov (250°C - 10 min, po 6–7 min vymeniť plechy). Pred pečením poprepichovať cesto.",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "ea1a9bd2-621c-48c8-bd02-f2dd4b293c7c",
      "url": null,
      "text": "Žĺtky vymiešať s práškovým cukrom. Pridať orechy, polohrubú múku, kypriaci prášok a sneh z bielkov. Spolu vymiešať a upiecť (175 °C, cca 18 min).",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "ac70665c-9edb-48db-937b-6505795d90b7",
      "url": null,
      "text": "Krém:\tZ mlieka, hladkej múky, vanilkového cukru a rumu uvariť hustý krém. Maslo vymiešať s práškovým cukrom. Vychladnutú kašu zmiešať s maslovým krémom.",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "ef46b340-8c91-4771-857c-23aa0fa51bd3",
      "url": null,
      "text": "Jednu časť lístkového cesta potrieme ½ krému, prikryť orechovým cestom. Na orechové cesto natrieť druhú časť plnky a zakryť druhým lístkovým cestom. Posypať práškovým cukrom a nechať stáť cez noc v chlade.",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    }
  ],
