  "instructions": [
    {
      "id": "f77e4e44-baf3-4534-a10f-0bdac9d37a59",
      "url": null,
      "text": "Postup :\t\t",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "64011907-9867-43af-904d-ca2536068cd8",
      "url": null,
      "text": "Vyšľaháme celé vajcia s oboma cukrami do peny. Vmiešame múku s práškom do pečiva, citrónovou kôrou a pečieme 20 min pri 180 °C. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "d312b64e-a461-4122-9b51-072fa7242b2c",
      "url": null,
      "text": "Kokosovú múčku varíme s 250 ml mlieka, kým sa tekutina neodparí. Z pudingového prášku, cukru a zvyšného mlieka uvaríme puding, do ktorého zahorúca vmiešame 50 g masla. Zvyšné maslo vyšľaháme s rumom a zmiešame s vychladnutým pudingom. Nakoniec pridáme kokosovú zmes.",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "571e1c74-c70f-4376-b647-3ffb91d02f8f",
      "url": null,
      "text": "Korpus 2x prekrojíme, spodný plát pokropíme rumom, natrieme lekvárom a 1/3 krému. Uložíme ďalší plát, postup zopakujeme. Vrchný plát, pokropíme rumom,  natrieme krémom a uložíme ovocie. Založíme obruč a polejeme vlažným želé pripraveným podľa návodu. Po stuhnutí boky zatrieme krémom, obložíme piškótami (ak dlhé zrezať) a previažeme stuhou.",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    }
  ],
