  "instructions": [
    {
      "id": "8a7de3a7-2bb3-4acc-9136-3bf02ab34c6f",
      "url": null,
      "text": "Kuracie prsia umyte, osušte a nakrájajte na menšie kúsky alebo rezne.",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "83e20041-5fe1-4993-a873-fafa624a1d3f",
      "url": null,
      "text": "Na panvici rozohrejte olivový olej a kuracie prsia opečte z každej strany, kým mäso nezbelie.",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "74f32697-8dde-4204-a100-26d6bf5e70e0",
      "url": null,
      "text": "Pridajte soľ, mleté čierne korenie a sušenú vanilku. Premiešajte, aby sa aróma uvoľnila.",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "dc0f3e52-ae1b-41e9-a1a7-3acec4e230af",
      "url": null,
      "text": "Podlejte pripraveným vývarom (alebo vodou) a chvíľu poduste, kým sa tekutina trochu neodparí.",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "3125860b-4925-4785-9ecc-6d171ba43339",
      "url": null,
      "text": "Prilejte kokosové mlieko a pridajte lyžičku medu. Omáčku dôkladne premiešajte a nechajte ju krátko prebublať do zhustnutia.",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    },
    {
      "id": "25d25c85-6be0-4546-82ef-7ae7a0f09bb2",
      "url": null,
      "text": "Podávajte s ryžou.",
