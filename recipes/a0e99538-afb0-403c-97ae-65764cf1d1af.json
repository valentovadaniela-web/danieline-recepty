  "instructions": [
    {
      "id": "5dbbf40e-949f-4af2-b9c9-4c5c7e0935db",
      "url": null,
      "text": "Kornútky:\tOplátky nakrájať na štvorce. Nad parou sa z nich urobia kornútky. ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "f959ec90-9feb-4168-bf26-bff7e6efcfb1",
      "url": null,
      "text": "Plnka – 1. časť: Do vriaceho mlieka zamiešať Zlatý klas, 3 žĺtka a uvariť puding. Miešať až do vychladnutia aby sa neurobili hrčky\t\t",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "2ef639a7-e9a5-4af6-8e6c-06cc3995a199",
      "url": null,
      "text": "Plnka – 2. časť: \tZ 5 bielkov ušľahať sneh. Pridať 5 lyžíc práškového cukru a uvariť nad parou.",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "494f3f03-d78e-4f1d-b084-73af4d8895e1",
      "url": null,
      "text": "Plnka – 3. časť: \tZmiešať maslo, 20 dkg práškového cukru a 1 vanilkový cukor.",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "1ed59d2b-3a8a-4728-9331-4b5cfa3985dc",
      "url": null,
      "text": "Zmiešať všetky tri časti plnky a plniť kornútky. Vrch a spodok zmrzlín sa namočiť do čokolády.",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    }
