  "instructions": [
    {
      "id": "44d902aa-ed9e-4c4a-aa31-5898b1f75c02",
      "url": null,
      "text": "Mlieko zohrejeme na 38 °C. Potom vlejeme 2,5ml syridla, dobre premiešame a necháme odstáť 45 minút.",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "bba46d61-b3e5-4a90-9eec-67378b1668c2",
      "url": null,
      "text": "Dlhým nožom nakrájame na štvorčeky a za stáleho miešania zohrejeme na 42°C.",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "cbb6fbaa-51b3-4131-9b21-bfcbb477fe04",
      "url": null,
      "text": "Necháme odstáť 20 minút. Potom vyberieme syr sitkom tak, že hmotu čo najviac zbavíme vody (prípadne vyžmýkame rukami)",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "067440be-88af-4272-bbdc-312e14a6e40d",
      "url": null,
      "text": "Dáme do formy (sitka) s dierkami, vystelieme gázou alebo plienkou. Naplníme formu, vrch syra prikryjeme gázou, zaťažíme tanierikom a činkou (na 1 kg syra 3 kg činka). Necháme cez noc v chladničke zaťažené.",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "b45c1fb9-4b54-4968-a697-51ac3fc23c88",
      "url": null,
      "text": "Na druhý deň spravíme slaný nálev: 140g soli na 1 liter vody (soľ dobre rozmiešame) a vložíme syr.",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    },
    {
      "id": "9af419cf-4dda-4b36-a5d5-505ab76b9f68",
      "url": null,
      "text": "Cca po 4 – 6 hod. vyberieme z nálevu (môžeme nechať aj cez noc)",
      "image_url": null,
      "sort_order": 5,
      "is_group_header": false
    }
  ],
