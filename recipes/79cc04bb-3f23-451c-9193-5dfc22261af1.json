  "instructions": [
    {
      "id": "117b2227-4663-42f6-b5da-9da18379d2be",
      "url": null,
      "text": "Heru vymiešame so žĺtkami a cukrom, pridáme klinčeky, škoricu, strúhanú citrónovú kôru, rum, med a droždie. Všetko premiešame, až kým masa nespení a mierne nezhustne. ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "18241e8a-54f0-4055-8935-61d1f8339d1f",
      "url": null,
      "text": "Pridáme múku s práškom do pečiva, umyté hrozienka, posekané orechy a nakoniec sneh z bielkov. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "c7d5f5dc-37a9-454c-aee7-eea586e7d417",
      "url": null,
      "text": "Vylejeme na plech vystlaný papierom na pečenie. Upečieme pri 175°C –  cca 20-25 min. Po upečení necháme vychladnúť a posypeme práškovým cukrom.",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    }
  ],
