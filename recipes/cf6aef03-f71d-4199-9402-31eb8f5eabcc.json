  "instructions": [
    {
      "id": "21a8c464-ebe1-484c-8011-974a7ae81c3a",
      "url": null,
      "text": "Deň vopred slivky umyjeme a zalejeme bielym vínom. Bravčovú panenku umyjeme, osušíme a urobíme do nej „tunel“ po celej dĺžke. Natlačíme doň napučané slivky, osolíme, okoreníme a na panvici opečieme zo všetkých strán. Dáme do jenskej misy a pečieme 20 min pri 180 °C.  Nakrájame na plátky.",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "20ee6dfa-11fb-4f7b-bb3f-7d55adf73b82",
      "url": null,
      "text": "V panvici rozpustíme šípkový lekvár, zalejeme trochou zeleninového vývaru, dochutíme soľou a korením.",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "14900ea7-41e6-4d22-b306-6c83602a6f7b",
      "url": null,
      "text": "Cibuľu a slaninu nakrájame na drobno a spolu upražíme do zlatista. Pridáme PL slivkového lekváru, červené víno, korenie, soľ a necháme prevrieť a zvariť na hustejšiu omáčku. Zmixujeme.",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "c4fecde7-b1b2-4a3a-a476-6f9e86185515",
      "url": null,
      "text": "Tip: Podávame s viedenskou knedľou.",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    }
  ],
