  "instructions": [
    {
      "id": "90a523b0-4f4c-4da5-9e6a-b0133a9b2a95",
      "url": null,
      "text": "Bielky s cukrom vyšľaháme dotuha. Pridáme kokos, preosiatu múku zmiešanú s práškom do pečiva. Rovnomerne rozotrieme na plech s papierom na pečenie. Pečieme 20 – 25 min pri 180 °C. ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "cf6808df-4375-4dca-9ba9-f928c6a739fb",
      "url": null,
      "text": "Žĺtky s cukrom, kakaom a kávou vyšľaháme nad parou do zhustnutia. Maslo vymiešame s 2 ČL cukru a pridáme vychladnutú žĺtkovú masu. Maslo a žĺtková masa musia mať rovnakú teplotu. Natrieme na koláč.",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "ccecb2fe-2861-458f-aa2f-c50aea0097a8",
      "url": null,
      "text": "Nad parou rozpustíme čokoládu a Ceru a polejeme koláč.",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    }
  ],
