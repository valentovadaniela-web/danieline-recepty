  "instructions": [
    {
      "id": "040e6284-cc8c-48e1-ae38-2f458f7c4610",
      "url": null,
      "text": "Mäso nakrájané na medailónky naklepeme a osolíme. ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "ebf4ebf4-5f44-459c-a33d-1c5d3656c1e4",
      "url": null,
      "text": "Opražíme na oleji a pridáme nakrájanú cibuľu. Podusíme. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "095d491c-94a4-4c0d-8c07-1c7273729e69",
      "url": null,
      "text": "Pridáme nastrúhanú zeleninu, korenie, štipku nastrúhaného muškátového orecha, podlejeme červeným vínom a dusíme. Počas dusenia pridáme karamel a zavárané brusnice. ",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "64c18427-960e-45eb-9b6b-bfe60aff5ef1",
      "url": null,
      "text": "Keď je mäso mäkké (cca 1 – 1,5 hod), vyberieme ho a môžeme krátko zapiecť v rúre spolu s kúskami rozmarínu. ",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "a76f45dc-711c-4438-801d-e733aef9cdb9",
      "url": null,
      "text": "Šťavu spolu so zeleninou rozmixujeme najemno a zvaríme spolu so šľahačkou, do ktorej sme pridali lyžicu múky. ",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    },
    {
      "id": "ab772a50-a5b5-4ded-b667-7a089910781a",
      "url": null,
      "text": "Podávame s knedľou alebo opekanými zemiakmi.",
      "image_url": null,
      "sort_order": 5,
      "is_group_header": false
    }
  ],
