  "instructions": [
    {
      "id": "36e0a37c-8fc4-4471-8b77-72ecee28e7ff",
      "url": null,
      "text": "Kuracie prsia nakrájame na cca 2 cm prúžky. Dáme ich do hlbokej misky a nasypeme zložky marinády a zalejeme vodou až po vrchnú vrstvu. Zamiešame.",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "db16e8b1-be23-4d70-ac01-24563fcc448d",
      "url": null,
      "text": "Dáme na 2 hodiny do chladničky.",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "6b3b1fcd-612b-4da5-8daa-f4e79170c3a1",
      "url": null,
      "text": "Do hladkej múky zamiešame soľ, korenie, cesnak, vajíčko a zriedime vodou na konzistenciu cesta na palacinky. ",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "cc0896e9-fff4-4177-93c2-3fb2d5d1f7de",
      "url": null,
      "text": "V druhej miske zmiešame múku, soľ a papriku.",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "283dabf7-56b4-4393-95ef-5be9a42966c6",
      "url": null,
      "text": "Do hlbokej panvice alebo hrnca nalejeme olej (aj liter). Obalíme stripsy v zmesi I a zmesi II a vyprážame 4-5 min v rozpálenom oleji.",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    }
  ],
