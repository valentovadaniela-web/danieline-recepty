  "instructions": [
    {
      "id": "13638d69-7997-4409-b432-d6a58a8a028a",
      "url": null,
      "text": "Zemiaky očistíme, nakrájame na ľubovoľnú veľkosť a dáme variť s bobkovým listom, osolíme a okoreníme. ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "91fb7247-cab8-465b-9ac5-2a23426f1991",
      "url": null,
      "text": "Keď sú zemiaky mäkšie pridáme smotanu a mlieko. Necháme povariť. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "0077ae08-35b0-4a7b-8a30-2a3a730702ee",
      "url": null,
      "text": "Na zahustenie prilejeme mlieko zmiešané s hladkou múkou. ",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "9777c691-1fba-4ca9-8a4c-989f2026a65c",
      "url": null,
      "text": "Pridáme trochu masla a cukor. ",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "75dcc595-aa66-4f8c-9af6-6fe5e5f9d1f3",
      "url": null,
      "text": "Potom varím ešte asi 15 minút. ",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    },
    {
      "id": "3228f440-a7cd-4008-9dd3-ed561c9c1ecf",
      "url": null,
      "text": "Takto hotový prívarok dochutíme horčicou.",
      "image_url": null,
      "sort_order": 5,
      "is_group_header": false
    },
    {
      "id": "ff43ffe6-c78a-4772-9177-41de08335704",
      "url": null,
      "text": "Podávame s fašírkou, sekanou alebo opečeným špekáčikom.",
      "image_url": null,
      "sort_order": 6,
      "is_group_header": false
    }
  ],
