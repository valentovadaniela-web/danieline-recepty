    },
    {
      "id": "52d37fb0-51b0-47be-8564-8a989d46ff02",
      "url": null,
      "text": "Zalejeme ju smotanou a vodou, osolíme, pridáme postrúhanú očistenú tekvicu, rascu a povaríme.",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "f9111df5-94af-411a-85d4-26976ecd456a",
      "url": null,
      "text": " Nakoniec okyslíme horčicou a pridáme posekaný kôpor. ",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "e4058df7-f657-41c0-948f-d4dd7e8bed6d",
      "url": null,
      "text": "Podávame s na paprike a cibuli poduseným mäsom.",
