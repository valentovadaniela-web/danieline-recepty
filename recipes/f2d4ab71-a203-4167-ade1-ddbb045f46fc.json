  "instructions": [
    {
      "id": "a918fbf3-c2ef-491c-9eb9-a3612c51925e",
      "url": null,
      "text": "Bielky s cukrom vyšľaháme na tuhý sneh, pridáme olej, žĺtky a zľahka primiešame múku s práškom do pečiva a kakao. ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "91c69d54-ee66-421b-83ef-4a94fe0eb5d8",
      "url": null,
      "text": "Cesto rovnomerne rozotrieme na plech (na papier na pečenie) a upečieme.",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "9f4ebbd6-758a-4265-bc93-7c107df8b1b3",
      "url": null,
      "text": "Väčšiu časť vody dáme zovrieť, pridáme 70 g cukru a vanilkový cukor. ",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "a474b558-d9ba-4898-a420-c76399adb71f",
      "url": null,
      "text": "Vo zvyšnej vode rozmiešame Zlaté klasy a prilejeme k vriacej vode. ",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "b15f3466-2c31-416f-aeb9-43ba4b1fca73",
      "url": null,
      "text": "Do horúcej kaše postupne zamiešame sneh z bielkov a 60 g cukru. Do polovice zamiešame kakao.",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    },
    {
      "id": "a58897c1-531f-40bd-b5a4-e0292359fd92",
      "url": null,
      "text": "Na cesto natrieme najprv svetlú, potom tmavú plnku. ",
      "image_url": null,
      "sort_order": 5,
      "is_group_header": false
    },
    {
      "id": "262605ec-8491-4581-9f0c-ff7c3290b012",
      "url": null,
      "text": "Navrch dáme karamelový krém: Cukor upálime, zalejeme mliekom, rozvaríme a do vychladnutého pridáme šľahačky v prášku a vyšľaháme.",
      "image_url": null,
      "sort_order": 6,
      "is_group_header": false
    },
    {
      "id": "cb9f1c5f-ad01-4123-a390-d7e636d83f79",
      "url": null,
      "text": "Povrch ozdobíme strúhanou čokoládou.",
      "image_url": null,
      "sort_order": 7,
      "is_group_header": false
    }
  ],
