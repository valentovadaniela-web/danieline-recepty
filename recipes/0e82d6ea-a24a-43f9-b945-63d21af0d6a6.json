  "instructions": [
    {
      "id": "67a52f9f-01e9-4982-a869-6e835e1a7f17",
      "url": null,
      "text": "Cesto si po vykysnutí rozdelíme na 2 veľké časti a jednu malú. ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "7de5f1c5-0b13-4c27-b8fc-e689e451bf96",
      "url": null,
      "text": "Prvú veľkú časť rozdelíme na 4 ks a vyvaľkáme placky (cca 18 cm), 3 potrieme plnkou a naukladáme na seba. Posledný vrchný plát musí byť väčší, aby sme ním mohli prekryť zvyšné 3. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "5fbfa952-9d81-4111-bf9d-bc7323b1fbe8",
      "url": null,
      "text": "Dáme na plech (do 30 cm tortovej formy) a narežeme na 16 trojuholníkov (nie až po okraj). ",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "e78cff01-d594-4018-ae72-5e60cfe149ee",
      "url": null,
      "text": "Zvnútra vyhneme všetky cípy von. ",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "29b9c950-e64a-4825-9e60-7ddf50800e99",
      "url": null,
      "text": "S druhým veľkým cestom to opakujeme (musí byť menšie, cca 13 cm) a vložíme dovnútra. ",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    },
    {
      "id": "99d60073-4d8b-43d0-870e-c5ffec472879",
      "url": null,
      "text": "Narežeme tak, aby boli cípy na striedačku s predchádzajúcimi a vyhneme von. ",
      "image_url": null,
      "sort_order": 5,
      "is_group_header": false
    },
    {
      "id": "57fa1a18-b5ae-4195-a133-715b6d28f099",
      "url": null,
      "text": "S posledným malým kúskom cesta urobíme to isté (cca 8 cm) a vložíme do stredu. Ale nenarezávame.",
      "image_url": null,
      "sort_order": 6,
      "is_group_header": false
    },
    {
      "id": "7cc26129-4b31-4190-974e-b0f16cb25d1f",
      "url": null,
      "text": " Necháme ½ hodinu podkysnúť. ",
      "image_url": null,
      "sort_order": 7,
      "is_group_header": false
    },
    {
      "id": "f3eaf467-09d5-41bd-a676-384cefaa49b5",
      "url": null,
      "text": "Potrieme vyšľahaným vajíčkom a posypeme semienkami. ",
      "image_url": null,
      "sort_order": 8,
      "is_group_header": false
    },
    {
      "id": "a2b1daaa-2331-4847-bcc6-9ca882994667",
      "url": null,
      "text": "Odoberieme okraj tortovej formy. ",
      "image_url": null,
      "sort_order": 9,
      "is_group_header": false
    },
    {
      "id": "00ace5fc-0f19-4e41-bdcc-258826041b1c",
      "url": null,
      "text": "Pečieme 22-25 min na 190°C. ",
      "image_url": null,
      "sort_order": 10,
      "is_group_header": false
    }
  ],
