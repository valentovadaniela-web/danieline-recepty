  "instructions": [
    {
      "id": "cf88d002-d035-42e4-90fe-25d2fd7596ff",
      "url": null,
      "text": "Dobre vymiešať, pridať sneh z 9 bielkov a vyliať do tortovej formy (vymastenej a múkou vysypanej). Upiecť pri 175 °C cca 50 minút.",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "5a2384c5-1cd1-4738-8bf8-f6f58b6dfa5a",
      "url": null,
      "text": "V mlieku rozmiešať vajcia + žĺtok, cukor (práškový a vanilkové) a múku. Uvariť a nechať vychladnúť.",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "8f90d464-95ac-4c94-8bfe-5b72656939f8",
      "url": null,
      "text": "Do vychladnutej zmesi pridať maslo a do hladka vymiešať. Potom pridať kakao, mleté orechy a rum.",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "99fd9724-4d89-4b33-9330-640b1d786e87",
      "url": null,
      "text": "Tortu  prekrojiť (na 3 pláty), naplniť a poliať polevou. Ozdobiť.",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    }
  ],
