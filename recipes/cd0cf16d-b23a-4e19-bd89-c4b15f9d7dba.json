  "instructions": [
    {
      "id": "cf352afe-69bd-420c-8d17-fc23a5156606",
      "url": null,
      "text": "Bôčik najemno pomelieme. Pridáme vajcia, rozotretý cesnak, vegetu, mleté korenie, muškátový oriešok a soľ. Necháme 24 hodín odstáť.",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "366794c1-6a12-469d-968b-2f5114796bd1",
      "url": null,
      "text": "Mäsovú hmotu vložíme do mikroténového vrecka (ako tlačenku). Vrecko na oboch stranách dobre previažeme. Vrecko vložíme do hrnca s horúcou vodou a varíme 90 min. Po vybratí z vody necháme mortadellu vychladnúť vo vrecku. Potom vrecko odstránime a mäso obalíme v mletej paprike. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    }
