  "instructions": [
    {
      "id": "3167651a-5688-493c-98ae-e4ee86d9b649",
      "url": null,
      "text": " Vymiešame žĺtky s cukrom do penista. pridáme múku a sneh z bielkov. Hmotu vylejeme do vymastenej a múkou vysypanej formy a upečieme (175 °C, 20 min). Po vychladnutí vyklopíme a pozdĺžne prekrojíme.",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "931b9278-5a83-4324-8b8f-d86544e58ce5",
      "url": null,
      "text": "Maslo vymiešame so žĺtkami do peny. Mlieko zmiešame s múkou a cukrom a uvaríme na hustú kašu. Vychladnutú pridáme k maslovej zmesi. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "89936bde-bd16-459b-a41c-f465d5280cfc",
      "url": null,
      "text": "Spodný plát torty natrieme lekvárom. Natrieme 2/3 plnky a prikryjeme vrchným plátom. Vrch potrieme plnkou, pokryjeme malinami a jahodami a zalejeme želatínou. Obvod torty potrieme zvyšnou plnkou a posypeme kokosom. Ozdobíme šľahačkou (zmiešanou so stužovačom).",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    }
  ],
