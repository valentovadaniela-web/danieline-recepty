  "instructions": [
    {
      "id": "2f3c16a2-1500-4120-b74c-85dbd036fdf1",
      "url": null,
      "text": "Na citrónovú plnku si najprv zmiešame kryštálový cukor s kôrou z citrónov a štipkou soli.",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "516cd6ce-b67a-4e37-bcef-c3d55b2e1278",
      "url": null,
      "text": "Pridáme maslo a rozšľaháme. Postupne pridávame žĺtky. Vyšľaháme do krémova a nakoniec vmiešame citrónovú šťavu. Plnka sa môže trochu „zraziť“, ale to nevadí, lebo ďalší krok je varenie a varom sa nám z plnky stane krásny homogénny citrónový krém.",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "0afd869a-8c21-4065-b9f5-3d15e3c715bc",
      "url": null,
      "text": "Varíme na slabom stupni asi 10 minút za občasného miešania, potom odstavíme a necháme vychladnúť. Chladom začne krém hustnúť a nadobudne konzistenciu džemu.",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "812047be-ff60-49e6-92c5-b7aacfdf212e",
      "url": null,
      "text": "Nalejeme ju (cez sitko) do menšieho zaváraninového pohára a uzavretú ju takto skladujeme v chladničke pokojne aj niekoľko týždňov.",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "d7d2e778-e7df-47f6-bc3f-a68957332245",
      "url": null,
      "text": "Z tejto dávky vám vyjde jeden malý zaváraninový pohárik, ak máte možnosť a prebytočné žĺtky, rovno si navarte krému viac.",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    }
  ],
