  "instructions": [
    {
      "id": "f576b803-db4d-4c2d-bf11-f84754b1c680",
      "url": null,
      "text": "Na oleji speníme cibuľu, poprášime červenou paprikou, osolíme. ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "bcd429c9-88ed-40be-a33b-628745d3ecaa",
      "url": null,
      "text": "Pridáme na menšie kúsky pokrájanú dobre umytú kučierku a zalejeme vodou. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "a749f7fe-2241-4759-833f-399a5094e65f",
      "url": null,
      "text": "Varíme cca 20 – 30 min (domäkka), potom zahustíme zápražkou (na oleji alebo Here opražíme múku 1:1, kým nezačne jemne hnednúť a voňať, zalejeme/zriedime studenou vodou a rozmiešame dohladka).",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "f6b97754-b8b4-4bed-a80b-06e4da08d34f",
      "url": null,
      "text": "Dochutíme rozotretým cesnakom, pridáme trošku vegety (alebo hovädzieho bujónu), rascu a majorán.",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    }
  ],
