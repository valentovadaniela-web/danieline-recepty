  "instructions": [
    {
      "id": "504123e5-b32e-42f0-90c0-37e613f439ac",
      "url": null,
      "text": "Rožky nakrájame na kocky cca 1x1 cm. ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "6f568bdc-c14d-4fd9-8d92-db56a78435e1",
      "url": null,
      "text": "Do misy dáme olej, mlieko a múku, pridáme vajcia, petržlenovú vňať, koreniny a soľ a dobre rozmiešame. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "7b9d04c4-dca6-43d9-84b6-4ec029a94d22",
      "url": null,
      "text": "Prisypeme nakrájané rožky a zmes dáme do mikroténových sáčkov (4), vytvarujeme valčeky a necháme 30 min odpočívať. ",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "b40d099f-0f57-42bd-a1ed-28df738e03e2",
      "url": null,
      "text": "Potom ich vložíme do vriacej vody a po chvíli popicháme špáradlom. Po 15 min varenia ich otočíme a varíme ďalších 15 min. ",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "6ceb39cd-9b24-4f3a-91e7-bdd0db6bdbeb",
      "url": null,
      "text": "Hotové potrieme olejom.",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    },
    {
      "id": "bd6e267c-c361-4836-9c1e-a40850bdcf25",
      "url": null,
      "text": "Nakrájame na kolieska.",
      "image_url": null,
      "sort_order": 5,
      "is_group_header": false
    }
  ],
