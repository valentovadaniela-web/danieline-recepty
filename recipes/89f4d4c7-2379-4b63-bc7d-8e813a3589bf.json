  "instructions": [
    {
      "id": "f91975f3-21b6-47af-b5bd-486b45e8ed80",
      "url": null,
      "text": "Bôčik pomelieme, osolíme a postupne doň zapracujeme surové mlieko. Uložíme na chladné miesto. ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "c94032d1-c980-40db-9bb2-209a02ecc2cf",
      "url": null,
      "text": "Na druhý deň vmiešame do mäsa postrúhaný syr. Mokrými rukami vyformujeme rezne a obalíme ich v hladkej múke, rozšľahanom vajci a strúhanke. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "6b8db102-b472-4b15-b016-e1e0cea96237",
      "url": null,
      "text": "Rezne vypražíme na horúcom oleji.",
