  "instructions": [
    {
      "id": "76636aac-9b07-4558-926c-7c21d18ffe00",
      "url": null,
      "text": "Kuracie prsia nakrájame na cca 2 cm prúžky. Dáme ich do hlbokej misky a zalejeme studenou vodou až po vrchnú vrstvu.",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "3714f0a0-7159-4745-ab45-212c7ec7babd",
      "url": null,
      "text": "Zasypeme zmesou korenia. Pridáme bazalku. Ak majú byť štipľavé, pridáme aj kajenské korenie. Pridáme čajovú lyžičku soli. Zamiešame. Môžeme ostrým nožom poprepichovať mäso, aby lepšie vsiaklo marinádu.",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "a184c1fa-cc9e-4960-a3b2-a67e5e3157e6",
      "url": null,
      "text": "Dáme minimálne na hodinu do chladničky.",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "8c942485-b6c7-40ae-a27c-4cf6bb7f7c67",
      "url": null,
      "text": "Do hladkej múky zamiešame Solamyl, lyžičku soli, červenú papriku, lyžicu koreniacej zmesi, bazalku a môžeme pridať 2 ČL kajenského korenia.",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "a0c02a7a-9a9e-4414-afb7-28e78902bd03",
      "url": null,
      "text": "Do hlbokej panvice alebo hrnca nalejeme olej (aj liter). Obalíme stripsy v múkovej zmesi a vyprážame 4-5 min v rozpálenom oleji.",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    }
  ],
