  "instructions": [
    {
      "id": "dbaaf59e-d0d9-49d6-a3c1-4a4a36a54057",
      "url": null,
      "text": "Tvaroh, maslo, cukor a vajcia vymiešame. Zmiešame 2 dcl prevareného mlieka a želatínu. Všetko dáme do mixéra, pridáme vanilkový cukor a zmixujeme. Rozdelíme na tretiny.",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "8ff63745-892a-4d31-a254-e85918adf607",
      "url": null,
      "text": "Dno tortovej formy vyložíme alobalom a poukladáme naň piškóty namočené v sirupe alebo ovocnej šťave. Nalejeme prvú tretinu masy a posypeme hrozienkami.",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "178da66f-28d6-4727-9a23-2ab88fdb2c0d",
      "url": null,
      "text": "Do druhej tretiny masy primiešame džem, vymiešame do hladka a nalejeme do formy. Nemusí byť rozvrstvená rovnomerne, vrstvy sa musia prelínať.",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "16713d0d-7c0c-473e-a5e4-a7c521c03115",
      "url": null,
      "text": "Tretiu tretinu zmiešame s kakaom a nalejeme na vrch torty. ",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "206d1a1b-34dc-4c4b-8cfe-ef4c5a8aa486",
      "url": null,
      "text": "Dáme do chladničky na 3 – 5 hodín.",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    },
    {
      "id": "edd206ae-8727-4d81-92ea-1b5b6a10437e",
      "url": null,
      "text": "Podávame ozdobené ovocím a šľahačkou",
      "image_url": null,
      "sort_order": 5,
      "is_group_header": false
    }
  ],
