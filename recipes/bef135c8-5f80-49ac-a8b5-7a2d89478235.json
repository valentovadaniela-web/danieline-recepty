      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "3e0239ba-2b9e-4c75-a11e-852640fe0f55",
      "url": null,
      "text": "Zľahka potrieme olejom a dáme na plech vystlaný papierom na pečenie. ",
