  "instructions": [
    {
      "id": "26716ac0-6eef-4494-88e9-c197d5d59b64",
      "url": null,
      "text": "Ingrediencie v uvedenom poradí zamiesime a necháme aspoň 1,5 hod vykysnúť. ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "217b0924-a370-4ba5-b8d1-70f403d6624f",
      "url": null,
      "text": "Po vykysnutí rozdelíme na 12 kúskov. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "96c443bf-edd4-4f34-9195-3a7c10cd38a3",
      "url": null,
      "text": "Na mierne pomúčenom stole z nich vyváľame valčeky, ohneme do tvaru lúpačiek, dáme na plech a necháme ďalších 10-40 minút kysnúť. ",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "7763e736-4c0c-43d5-adc9-eb3ae86a2d6c",
      "url": null,
      "text": "Potom potrieme bielkom a posypeme makom.",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "343a4bca-5844-4995-9835-a07ac29a3cff",
      "url": null,
      "text": "Dáme do vyhriatej rúry a pečieme dozlata pri 200 °C cca 15-20 minút.",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    }
  ],
