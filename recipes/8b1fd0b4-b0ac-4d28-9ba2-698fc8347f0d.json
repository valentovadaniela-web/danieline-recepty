  "instructions": [
    {
      "id": "349f58c6-90f5-45d6-a213-d4821cd32352",
      "url": null,
      "text": "Cibuľu ošúpeme, nadrobno nasekáme a podusíme na rozohriatom oleji. Pridáme ryžu, zalejeme vínom a vývarom a dusíme približne 20 - 30 minút.",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "717f3184-3396-4eef-8a1f-0e64fff45645",
      "url": null,
      "text": "Kuracie mäso umyjeme, osušíme, osolíme, okoreníme a opečieme z oboch strán na rozohriatom masle. Cesnak očistíme, roztlačíme a spolu s rozmarínom pridáme na kuracie mäso. Dusíme približne 10 minút a prie-bežne polievame výpekom.",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "57782720-ed8e-47dd-b288-fc00492962b6",
      "url": null,
      "text": "Šľahačku s citrónovou šťavou, kôrou a syrom okoreníme a povaríme. Ak treba, zahustíme múkou alebo zriedime mliekom. Podávame s karí ryžou.",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    }
  ],
