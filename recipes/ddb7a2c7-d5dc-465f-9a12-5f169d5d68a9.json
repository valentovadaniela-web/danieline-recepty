  "instructions": [
    {
      "id": "f66d29c8-046e-4a3f-a8fe-da3ac7be1419",
      "url": null,
      "text": "Bielka vyšľaháme do tuhej peny a postupne pridáme vanilkový a kryštálový cukor. Keď dostaneme tuhú lesklú penu, pridáme vidličkou rozšľahané žĺtka a nakoniec zľahka primiešame múku s kakaom a orechy. Na plech vyložený papierom na pečenie navrstvíme tenkú vrstvu a pečieme 15 min pri 180 °C. Ihneď po upečení dáme dole papier a stočenú roládu necháme vychladnúť.",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "1d12944e-4882-4f29-b89d-444a000dff02",
      "url": null,
      "text": "Vyšľaháme šľahačku so stužovačom a cukrom a zmiešame s maskarpone. Plnku natrieme na cesto a zrolujeme.",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "8d3ce77c-7efd-4b19-9fab-bf828504862e",
      "url": null,
      "text": "Necháme v chladničke stuhnúť. Pred podávaním posypeme práškovým cukrom.",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    }
  ],
