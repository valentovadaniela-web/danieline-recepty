  "instructions": [
    {
      "id": "7e59916e-92e6-4b74-8879-6df15006c81a",
      "url": null,
      "text": "Zmiešať žĺtky, práškový cukor, vodu a olej. Pridať múku s práškom do pečiva a sneh z bielkov. Vyliať na vymastený plech (netreba múku). Upiecť (275°C, 15min). Hneď  zvinieme na roládu.",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "52997d21-c190-4c56-9047-e110f32e50da",
      "url": null,
      "text": "Suroviny na plnku vyšľahať. Ešte teplú roládu znovu rozvinúť a na-trieť ¾ krému. Zrolovať a natrieť zvyškom krému.",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "d5bdf6bb-b525-49c9-8257-134924d7309e",
      "url": null,
      "text": "Nakoniec posypať strúhanou čokoládou.",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "4ae03c1a-3558-49f5-8215-2fa28130afea",
      "url": null,
      "text": "Nechať aspoň 1 hod v chlade.",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    }
