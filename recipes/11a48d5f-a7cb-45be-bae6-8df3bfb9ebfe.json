  "instructions": [
    {
      "id": "b59707ed-fe76-4f87-8d28-8f0d50a56f49",
      "url": null,
      "text": "Obe Salká dáme na dve hodiny variť, potom necháme vychladnúť. ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "9a6fca85-df1e-4476-8c63-bbae66f610e9",
      "url": null,
      "text": "Z mandľového pudingu a mlieka urobíme puding a mierne vychladíme za stáleho miešania, aby sa nám neurobila navrchu koža. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "f046ff34-cb74-4c6b-a482-0e106b646bd1",
      "url": null,
      "text": "Vlažný puding zmiešame s uvarenými Salkami a rumom. Precedíme do fliaš, aby neboli v nápoji hrudky. ",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "f0c24fe8-148b-4e93-8159-77862bcf5db4",
      "url": null,
      "text": "Dáme odležať na 12 hodín do chladničky a podávame vychladené s kockami ľadu.",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    }
