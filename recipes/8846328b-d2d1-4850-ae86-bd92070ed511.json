  "instructions": [
    {
      "id": "06f94f7a-7a7a-4aed-8dd5-430bd55c479a",
      "url": null,
      "text": "Menšie zemiaky dobre umyjeme a deň vopred uvaríme v šupke do mäkka. Necháme úplne vychladnúť a následne ošúpeme. ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "92ae45ff-fcbf-4f64-88e8-bb959981d744",
      "url": null,
      "text": "Očistené zemiaky dáme do misky, pridáme preosiatu múku, soľ a vymiešame hladké nelepivé cesto. Nemiesime príliš dlho, aby sa cesto nezačalo lepiť.",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "5f48bae6-7120-4d00-b9bf-7941cf817559",
      "url": null,
      "text": "Z cesta vypracujeme valček dlhý približne 45 cm a pokrájame na 2,5 cm hrubé kúsky. ",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "9e352f33-969a-4a96-8cc4-fe00c8198465",
      "url": null,
      "text": "Z každého kúsku vytvoríme guľôčky, ktoré rozvaľkáme na pomúčenej doske na placky o hrúbke 2-3 mm. ",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "f0a47316-89e3-4a6e-919c-86aa0e1bb941",
      "url": null,
      "text": "Panvicu (priemer 22-24 cm) rozpálime a placky pečieme na sucho z každej strany do zlatista. Počas pečenia priebežne utierame papierovými obrúskami zvyšnú múku z panvice, aby sa nám nepripálila. ",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    },
    {
      "id": "d4bcb1be-8409-4ff9-9a32-37e1406fb7ed",
      "url": null,
      "text": "Upečené lokše potrieme kačacou alebo husacou masťou a podávame.",
      "image_url": null,
      "sort_order": 5,
      "is_group_header": false
    }
  ],
