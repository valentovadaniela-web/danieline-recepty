  "instructions": [
    {
      "id": "7c5d0b27-39ea-432b-af89-e0f5b82a3410",
      "url": null,
      "text": "Žĺtky + cukor + vodu + olej vymiešať do peny. Striedavo pridávať múku s práškom do pečiva a sneh z bielkov. Do ½ cesta pridať kakao. Každú polovicu vyliať do inej formy na srnčí chrbát. Upiecť (pri 200°C – 20-25 min). Nechať vychladnúť.",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "c39ccf98-b02b-4841-b871-24127b1c0b42",
      "url": null,
      "text": "Mlieko + vanilkový cukor + Zlatý klas uvariť na krém a nechať vychladnúť. Vymiešať maslo + cukor. Zmiešať s vychladnutou maslovou hmotou. Dochutiť rumom.",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "8060eb1a-45e7-40ff-9c6d-e6de28bd4175",
      "url": null,
      "text": "Obe vychladnuté cestá nakrájať na rezy. Natrieť krémom a striedavo ukladať. Zvyšným krémom natrieť povrch. Poliať čokoládou. Krájať šikmo.",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    }
  ],
