  "instructions": [
    {
      "id": "9ebdec52-3cfa-4418-b14c-21fd8680be19",
      "url": null,
      "text": "V múke rozmiešame soľ, rozmrvíme maslo, pridáme cukor, žĺtky, rum alebo víno, smotanu a postrúhanú citrónovú kôru. ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "26900c98-4d22-4eed-8bfa-7e10487fa4ef",
      "url": null,
      "text": "Všetko spolu vymiesime, prikryjeme obrúskom a necháme pol hodiny odpočívať na múkou posypanej doske.",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "f4a671eb-dc20-425b-b0fd-144ec69ccdfd",
      "url": null,
      "text": "Cesto natenko vyvaľkáme a vykrajujeme kvetinky (3 veľkosti, ktoré poukladáme na seba, v strede spájame bielkom a pritlačíme) alebo ostronôžkou pokrájame na obdĺžniky, ktoré v strede 2x nakrojíme a prepletieme. ",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "1869d2a2-47c8-4f36-afeb-f0547a7fb649",
      "url": null,
      "text": "Opražíme na oleji do červena. Vypražené posypeme vanilkovým + práškovým cukrom. ",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "8c07663f-5d6e-4914-979a-0c4ee1859b45",
      "url": null,
      "text": "Do stredu kvetiniek môžeme dať lekvár.",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    }
  ],
