  "instructions": [
    {
      "id": "a00d9587-4a43-4764-925b-54da0cefc13e",
      "url": null,
      "text": "Z bielkov a štipky soli vyšľaháme tuhý sneh. ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "b0a20c5d-5f99-4598-88ba-26dde46b85d9",
      "url": null,
      "text": "Postupne doň zašľaháme cukor a po jednom žĺtky. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "41272fc2-1ec1-48de-83b7-4d7004dabe04",
      "url": null,
      "text": "Primiešame (preosiatu) múku. ",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "f538abb3-8c88-49cf-95a6-fd927add042f",
      "url": null,
      "text": "Cesto nalejeme na plech vystlaný papierom na pečenie. ",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "ca7bfe7a-992a-4994-b02a-9b8a822b15fd",
      "url": null,
      "text": "Jablká očistíme, zbavíme jadrovníka, nakrájame na tenké plátky a naukladáme ich na cesto. ",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    },
    {
      "id": "bf843613-9f58-40b8-a2fb-962ab4eb6729",
      "url": null,
      "text": "Posypeme škoricový cukrom. ",
      "image_url": null,
      "sort_order": 5,
      "is_group_header": false
    },
    {
      "id": "1e84c900-b3cf-43a3-b3f1-3272823576be",
      "url": null,
      "text": "Pečieme približne 25 -30 minút na 180 °C.",
      "image_url": null,
      "sort_order": 6,
      "is_group_header": false
    },
    {
      "id": "9201556c-375d-405d-8aaf-7be2eec021e1",
      "url": null,
      "text": "Po upečení posypeme práškovým cukrom.",
      "image_url": null,
      "sort_order": 7,
