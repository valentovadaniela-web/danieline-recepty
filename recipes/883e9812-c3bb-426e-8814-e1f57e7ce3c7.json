  "instructions": [
    {
      "id": "32f157ab-d641-4512-895b-e41d2f61620e",
      "url": null,
      "text": "Uvaríme silnú kávu. Pridáme Amaretto. ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "40e8bd00-0334-4485-b5ac-b239abb7c224",
      "url": null,
      "text": "Mascarpone vyšľaháme s cukrom a postupne primiešame vaječný koňak. Nakoniec pridáme vyšľahanú šľahačku. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "52f5fbc7-0ecb-4a6d-990e-35aee374ac3b",
      "url": null,
      "text": "Do jenskej misy alebo tortovej formy ukladáme piškóty, ktoré sme rýchlo omočili v káve. ",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "2ef8bf90-b538-4866-88ca-c94d2a350127",
      "url": null,
      "text": "Na piškóty navrstvíme krém. ",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "9264ba69-7bbf-4dc4-89ca-13670a0c0779",
      "url": null,
      "text": "Dáme druhú vrstvu namočených piškót a opäť vrstvu krému. Ak máme menšiu misu, môžeme urobiť 3 vrstvy. ",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    },
    {
      "id": "7fb9330f-52df-4b1f-91e2-c4803898d30f",
      "url": null,
      "text": "Poslednú hornú vrstvu krému posypeme kakaom. Hotové tiramisu necháme minimálne 5 hodín v chladničke stuhnúť.",
      "image_url": null,
      "sort_order": 5,
      "is_group_header": false
    }
  ],
