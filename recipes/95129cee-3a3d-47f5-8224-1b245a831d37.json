  "instructions": [
    {
      "id": "4126cc7a-556c-4fec-8698-ebd67cec5d0b",
      "url": null,
      "text": "Cesto:\t 6 žĺtkov + 18 dkg práškového cukru vymiešať do peny. Pridať múku s práškom do pečiva a sneh z bielkov. Upiecť (pri 175°C – 15-20 min) a nechať vychladnúť.",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "27287163-d007-4f21-b711-a6a0940abfd6",
      "url": null,
      "text": "Plnka:\t2 kyslé smotany, vanilkový cukor a vyšľahanú šľahačku zmiešať a natrieť na vychladnuté cesto. Na plnku poukladať na kolieska nakrájané kiwi.",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "44c5d76e-ba75-4f3c-8c8e-361fc556fcae",
      "url": null,
      "text": "Želatína: 4 dcl studenej vody + 2 dcl citrónového sirupu + 1 Zlatý klas + 10 dkg práškového cukru uvariť na hustú kašu a vychladnutú naliať na koláč.",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "32a38450-d167-47a7-80fb-f04d425a6d2b",
      "url": null,
      "text": "Nechať minimálne 1 hodinu (lepšie cez noc) v chlade.",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    }
  ],
