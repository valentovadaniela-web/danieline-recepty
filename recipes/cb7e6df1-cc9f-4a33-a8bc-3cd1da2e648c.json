  "instructions": [
    {
      "id": "0e1a12f6-89b8-40c2-b20b-d80595fc90d6",
      "url": null,
      "text": "Nad parou v hrnci zohrievame za stáleho miešania Salko spolu s kravským maslom. Miešame, dokým nevznikne redšia karamelová hmota. Odstavíme z ohňa a necháme vychladnúť.",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "16890b3f-7131-42f4-81bc-ce3df45b1213",
      "url": null,
      "text": "Nad parou v hrnci zohrievame za stáleho miešania cukor, maslo, vajce, mlieko a med. Miešame, dokým nevznikne hustejšia lepkavá hmota. Necháme 5 minút vychladnúť. V druhej miske preosejeme hladkú múku, do ktorej zamiešame prášok do pečiva. Pomaly po častiach primiešane horúcu zmes a vytvorí sa nám lepkavé cesto. Cesto vyvaľkáme na pomúčenej doske. Vrch cesta si tiež pomúčime, cesto je lepkavé, ale dá sa s ním napriek tomu dobre pracovať. Cesto vyvaľkáme zhruba na 0,5 cm hrúbku.",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "d86f4b87-eccf-44ea-94a6-98b4dc4929e1",
      "url": null,
      "text": "Cesto pečieme pri 180°C cca 10 minút. Po upečení necháme medový plát vychladnúť. Následne ho rozmixujeme v mixéri. Trošku zmesi odoberieme na obaľovanie guličiek.",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "1161970b-8db6-4472-8567-d91ac481e188",
      "url": null,
      "text": "Do väčšej misky nasypeme zvyšok rozmixovaných medových plátov a postupne primiešavame karamelovú zmes. Miešame, dokým nám nevznikne hustejšia hmota. Misku zakryjeme potravinovou fóliou a dáme aspoň na 3 hod do chladu.",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "3653c4bf-2697-428e-931e-4e9b36b85ba1",
      "url": null,
      "text": "Zo stuhnutého cesta tvarujeme v dlaniach guličky, ktoré potom obaľujeme v zmesi rozmixovaného cesta, ktoré sme si odložili bokom. Obalené guľky poukladáme do papierových mini košíčkov a podávame.",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    }
  ],
