      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "8947136e-2680-43fb-97a0-aae9af50a0a7",
      "url": null,
      "text": "Každým pásikom potom omotáme jeden párok. ",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "6c699caa-ea60-4810-91f5-598c9a8a7673",
      "url": null,
      "text": "Párky poukladáme na plech, potrieme rozšľahaným žĺtkom, osolíme a posypeme rascou. ",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "a5145abe-d84c-4559-869a-e9ac0ec8e2a1",
      "url": null,
      "text": "Upečieme do ružova (250 °C, cca 8 - 10 min).",
