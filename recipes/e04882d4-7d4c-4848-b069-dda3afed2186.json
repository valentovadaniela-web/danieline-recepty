  "instructions": [
    {
      "id": "7e58699a-2afd-423a-83d7-b309f1e2234d",
      "url": null,
      "text": "Žĺtky vymiešame s cukrom, pomaly primiešame horúcu kávu a vyšľaháme. Pridáme múku s práškom do pečiva a sneh. Pečieme 25 min pri 180 °C. Necháme vychladnúť. ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "eab19c4e-16c4-4053-94fb-1bf015ea47e2",
      "url": null,
      "text": "Z mlieka, kávy, múky, vanilkového cukru a žĺtka uvaríme hustý krém. Necháme vychladnúť. Maslo a cukor vymiešame do penista a spojíme ho s vychladnutou kašou.",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "28c9d3b5-c45c-4b5b-8ce6-5ecee7d43ef4",
      "url": null,
      "text": "Koláč prerežeme 1x priečne a 1x pozdĺžne. Tri pláty natrieme plnkou, uložíme na seba a zakryjeme štvrtým. Polejeme polevou, ktorú pripravíme zmiešaním precedenej horúcej kávy a cukru.",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    }
  ],
