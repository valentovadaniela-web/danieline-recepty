  "instructions": [
    {
      "id": "334cfef5-02cd-41c8-8cce-c0ef272184db",
      "url": null,
      "text": "Celé vajcia vyšľaháme s cukrom do penista. Postupne pridávame múku s práškom do pečiva, orechy a kakao. ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "83ed7a4e-1806-4923-af7f-4cfe80863ccc",
      "url": null,
      "text": "Nalejeme na plech vyložený papierom na pečenie. Pečieme pri 175 °C cca 15 min. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "8d7b9d66-0d21-4d9c-bba5-ef4617e59080",
      "url": null,
      "text": "Vychladnuté cesto potrieme lekvárom a rozložíme naň pozdĺžne prekrojené banány. ",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "86eb9d43-f1bf-4a2c-b906-5c6e2adb0253",
      "url": null,
      "text": "Maslo vymiešame s práškovým cukrom. Z mlieka, kryštálového cukru a vanilkového pudingu uvaríme hustú kašu. Do vychladnutého pudingu pridáme vymiešané maslo s cukrom, tvarohom a spolu vymiešame na hladkú masu, ktorú natrieme na banány. ",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "4477f98c-5d21-470b-b037-379329ee9a7c",
      "url": null,
      "text": "Naplnený koláč polejeme čokoládovou polevou. ",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    }
  ],
