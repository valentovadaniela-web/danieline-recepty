  "instructions": [
    {
      "id": "9778ec9f-8cce-4e14-82df-70a5ad0a58ba",
      "url": null,
      "text": "1. Korpus:",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": true
    },
    {
      "id": "7478fdcc-4dbc-4e43-9abb-a85c9d10bb38",
      "url": null,
      "text": "Žĺtky vyšľahaj s cukrom a vodou do hustej peny.",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "0dd92b39-c8a9-452f-be6b-f499976006d3",
      "url": null,
      "text": "Bielky vyšľahaj na tuhý sneh.",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "5c4e217a-adce-4549-ad5b-6055ad4cae51",
      "url": null,
      "text": "Zmiešaj múku, kakao a prášok do pečiva.",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "04a1734d-bfd9-458f-8f3b-e7eb7d040a05",
      "url": null,
      "text": "Do žĺtkovej hmoty striedavo vmiešavaj sneh a sypké ingrediencie.",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    },
    {
      "id": "5930defc-8090-480f-b9d2-f2326347a4a4",
      "url": null,
      "text": "Rozotri na plech vystlaný papierom na pečenie.",
      "image_url": null,
      "sort_order": 5,
      "is_group_header": false
    },
    {
      "id": "af124643-d849-4d5d-a04d-a6cd8bc03f13",
      "url": null,
      "text": "Peč pri 180 °C približne 20–25 minút.",
      "image_url": null,
      "sort_order": 6,
      "is_group_header": false
    },
    {
      "id": "73aea8f5-d1f0-4326-8353-18e72296f32e",
      "url": null,
      "text": "2. Žĺtkový krém:",
      "image_url": null,
      "sort_order": 7,
      "is_group_header": true
    },
    {
      "id": "b0c70386-8a37-4ccb-8cde-4243f7bb64a1",
      "url": null,
      "text": "V mlieku rozmiešaj žĺtky, múku a vanilkový cukor.",
      "image_url": null,
      "sort_order": 8,
      "is_group_header": false
    },
    {
      "id": "87a02719-804f-4e92-ba9f-f1ae1ae75a01",
      "url": null,
      "text": "Za stáleho miešania uvar hustý krém.",
      "image_url": null,
      "sort_order": 9,
      "is_group_header": false
    },
    {
      "id": "b473fafd-91b4-42dd-b6e9-432d9f6ba25a",
      "url": null,
      "text": "Nechaj úplne vychladnúť.",
      "image_url": null,
      "sort_order": 10,
      "is_group_header": false
    },
    {
      "id": "10c8af9a-9918-4956-9979-491106a9f503",
      "url": null,
      "text": "Maslo vyšľahaj s práškovým cukrom do peny.",
      "image_url": null,
      "sort_order": 11,
      "is_group_header": false
    },
    {
      "id": "e0e7f161-4356-4e07-b7e9-608743697843",
      "url": null,
      "text": "Po lyžiciach zašľahaj vychladnutý základ.",
      "image_url": null,
      "sort_order": 12,
      "is_group_header": false
    },
    {
      "id": "52d5cadf-e643-4b28-9d68-212525b3d8e5",
      "url": null,
      "text": "3. Bielková pena:",
      "image_url": null,
      "sort_order": 13,
      "is_group_header": true
    },
    {
      "id": "66bbfe90-f1dc-45a8-8615-c70bbc7786c0",
      "url": null,
      "text": "Bielky, cukor a citrónovú šťavu daj nad vodný kúpeľ.",
      "image_url": null,
      "sort_order": 14,
      "is_group_header": false
    },
    {
      "id": "eea805f5-2ef7-4608-b91f-67df703bb3ad",
      "url": null,
      "text": "Šľahaj približne 8–10 minút, kým nevznikne hustá lesklá pena.",
      "image_url": null,
      "sort_order": 15,
      "is_group_header": false
    },
    {
      "id": "dd2cc991-0b47-4edc-b183-43968b823b35",
      "url": null,
      "text": "Pena musí držať tvar a nesmie stekať.",
      "image_url": null,
      "sort_order": 16,
      "is_group_header": false
    },
    {
      "id": "dffb9dbe-d556-412f-ad33-438dc59602e7",
      "url": null,
      "text": "4. Skladanie:",
      "image_url": null,
      "sort_order": 17,
      "is_group_header": true
    },
    {
      "id": "5d022a6a-e7c8-425b-ab23-6f0a9e66d037",
      "url": null,
      "text": "Na vychladnutý korpus natri žĺtkový krém.",
      "image_url": null,
      "sort_order": 18,
      "is_group_header": false
    },
    {
      "id": "3e3815b3-8b6f-4f23-a355-c663a35006a5",
      "url": null,
      "text": "Na krém rozotri bielkovú penu.",
      "image_url": null,
      "sort_order": 19,
      "is_group_header": false
    },
    {
      "id": "673c39a3-f71f-4372-8889-904f0193ce28",
      "url": null,
      "text": "Posyp jemne nastrúhanou horkou čokoládou.",
      "image_url": null,
      "sort_order": 20,
      "is_group_header": false
    },
    {
      "id": "5a45ff72-753a-4a4f-a3cd-6358098c11d4",
      "url": null,
      "text": "Daj stuhnúť do chladničky aspoň na 4 hodiny, ideálne cez noc.",
      "image_url": null,
      "sort_order": 21,
      "is_group_header": false
    },
    {
      "id": "58cdf974-b457-48e9-97a7-b8d0deee2f45",
      "url": null,
      "text": "Tip: Pod žĺtkový krém je možné natrieť tenkú vrstvu domáceho ríbezľového lekváru, ktorá jemne vyvážil sladkosť krému. ",
      "image_url": null,
      "sort_order": 22,
      "is_group_header": false
    }
  ],
