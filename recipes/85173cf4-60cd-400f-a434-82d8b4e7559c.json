  "instructions": [
    {
      "id": "65c6e567-f359-48b5-96d3-ecb02e875f87",
      "url": null,
      "text": "Žĺtky + cukor vymiešať do peny. Pridať múku s práškom do pečiva, vodu a sneh z bielkov. Cestom plniť vymastené a múkou vysypané formičky. Upiecť (175 až 200°C - 20 min, po 15 min vymeniť plechy).",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "dc7f8b88-3c6a-49f6-8a15-f44df82f7612",
      "url": null,
      "text": "Nad parou vymiešať vajcia + práškový cukor do zhustnutia. Do vychladnutej zmesi pridať vymiešané maslo a rum (Amaretto).",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "f3e25661-bd85-4a7e-bc07-670ad44241e8",
      "url": null,
      "text": "Vnútro koláčikov vydlabať, pokvapkať rumom a plniť krémom (1 ČL). Spájať po dvoch. Štetcom namaľovať a obaliť v jemnom kryštálovom cukre. Ozdobiť lístkom a ukladať do papierových košíkov.",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    }
  ],
