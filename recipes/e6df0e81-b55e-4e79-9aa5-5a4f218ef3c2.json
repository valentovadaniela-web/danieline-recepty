  "instructions": [
    {
      "id": "4e40573b-04ae-4757-823e-9072292c287c",
      "url": null,
      "text": "Syr nakrájame na plátky cca 2 mm hrubé a cca 9x9 cm veľké. ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "122d7082-0b13-4610-b6b7-5481f2dd95de",
      "url": null,
      "text": "Šampiňóny pokrájame na plátky a podusíme na masle. Pridáme hrášok, na rezance nakrájanú salámu, posekanú petržlenovú vňať a soľ. Prichutíme vegetou a mletým korením. Primiešame vajcia a necháme ich zraziť.",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "4ec24589-4ad3-4911-b73f-a02c37833032",
      "url": null,
      "text": "Na polovicu syrových plátkov uložíme tenkú vrstvu šampiňónovej plnky. Prikryjeme zostávajúcimi syrovými plátkami a pritlačíme. ",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "7d3bf707-8766-4484-bb0e-b4f91897a9dd",
      "url": null,
      "text": "Naplnené syrové rezne obalíme v múke, osolenom vajíčku a strúhanke. Môžeme ich dať na ½ hod do mrazničky, aby sa neroztekal. ",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "f5fdf9fd-a97f-47ce-a6fe-eea86cc85979",
      "url": null,
      "text": "Rezne po oboch stranách veľmi rýchlo opražíme na horúcom oleji.",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    }
  ],
