  "instructions": [
    {
      "id": "c861372d-ebdf-4f6d-b1d0-deae895e6234",
      "url": null,
      "text": "Kuracie rezne naklepeme, osolíme a okoreníme. ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "74f9b404-819a-4fb1-8b28-6d5e7a231587",
      "url": null,
      "text": "Formu na bábovku vyložíme papierom na pečenie. Formu na dne a po obvode vystelieme kuracími rezňami. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "37086e07-00f7-4252-b7a3-9f9d33c42446",
      "url": null,
      "text": "Naň dáme plátky slaniny, kocky salámu, nastrúhaný syr a rozbijeme celé vajíčka. ",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "6dcb4a0e-e991-42ab-a8f4-7a5da5bc940f",
      "url": null,
      "text": "Posypeme nasekanou pažítkou. ",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "8a8ef06b-34c3-48b1-bab1-08cdb3babb89",
      "url": null,
      "text": "Vrstvy sa opakujú, až kým nie je forma plná. Posledná vrstva je mäso. ",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    },
    {
      "id": "88cfca05-1b11-4a86-9d48-49de65f8834a",
      "url": null,
      "text": "Všetko zalejeme rozšľahaným vajíčkom so zvyškom syra. ",
      "image_url": null,
      "sort_order": 5,
      "is_group_header": false
    },
    {
      "id": "52716740-0224-4a99-9ae9-3e375f8751b2",
      "url": null,
      "text": "Pečieme asi 1,5 hod pri teplote 250 °C. Upečenú bábovku vyklopíme, necháme trochu vychladnúť a krájame.",
      "image_url": null,
      "sort_order": 6,
      "is_group_header": false
    }
  ],
