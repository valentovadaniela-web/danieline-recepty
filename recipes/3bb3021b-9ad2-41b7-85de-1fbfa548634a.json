  "instructions": [
    {
      "id": "3c0fc480-5cb1-4a0a-bdcd-1abb9ccd871a",
      "url": null,
      "text": "Papriku umyjeme a stopky so semenami vykrojíme. Krátko povaríme, aby trochu zmäkli. ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "fb5086da-43d3-42d3-98b5-b0b0f685a7f7",
      "url": null,
      "text": "Uvaríme ryžu domäkka. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "0ae766af-b30a-425d-b551-d346cefa2147",
      "url": null,
      "text": "Mäso a cibuľu zomelieme, osolíme, okoreníme, pridáme varenú ryžu a surové vajce. Dobre premiešame a naplníme papriky. Keď nám plnka zvýši, sformujeme guľky. ",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "98bb961d-598a-47a1-a072-8309a5a2e71d",
      "url": null,
      "text": "Z masti a múky pripravíme zápražku, zalejeme ju vodou, pridáme pretlak, cukor, soľ a povaríme. ",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "7201dbe7-50e4-4514-8c70-9961a78eb5a6",
      "url": null,
      "text": "Po prevarení vložíme do omáčky naplnené papriky. Varíme prikryté na miernom ohni. Občas premiešame, aby omáčka neprihorela. ",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    },
    {
      "id": "482193bd-18a9-499f-bb07-550861b88430",
      "url": null,
      "text": "Podávame s parenou knedľou.",
      "image_url": null,
      "sort_order": 5,
      "is_group_header": false
    }
  ],
