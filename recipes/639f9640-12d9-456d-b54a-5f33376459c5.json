  "instructions": [
    {
      "id": "f9dfb05e-b795-49a7-99b5-09020626c41a",
      "url": null,
      "text": "Na masti speníme cibuľu, pridáme cesnak a kocky mäsa, opečieme, zasypeme korením, zamiešame, posolíme a podlejeme vodou. ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "7f8cc198-4e61-4d24-9d6b-c761efad6311",
      "url": null,
      "text": "Guláš dusíme pod pokrievkou na slabom plameni. Keď mäso zmäkne, necháme vydusiť šťavu na tuk, pridáme pretlak, posypeme múkou a zamiešame. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "829cfe63-5420-4157-81ef-3c7454b94e9a",
      "url": null,
      "text": "Do hotového pokrmu vmiešame na oleji a rasci podusené nakrájané huby. ",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "bed2c3d4-3c87-41eb-a1ac-d4ad02477d3b",
      "url": null,
      "text": "Podávame s knedľou a brusnicovým džemom.",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    }
  ],
