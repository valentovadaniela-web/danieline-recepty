  "instructions": [
    {
      "id": "154edd8f-e6fa-4c33-82a3-a07022d8482c",
      "url": null,
      "text": "Múku s kypriacim práškom zmiešame s ostatnými prísadami, vypracujeme tuhé cesto a dáme ho na hodinu do chladničky.",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "f727836d-ef4f-4d6e-ad33-f5f263c15ae0",
      "url": null,
      "text": "Tvaroh zmiešame s cukrom, žĺtkami, maizeinou. Citrónovou kôrou, hrozienkami a postupne doň pridáme sneh z bielkov.",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "64af74ee-3ee2-421a-9008-ff3d146bf23d",
      "url": null,
      "text": "Polovicu cesta nastrúhame na plech vystlaný papierom na pečenie, na ňu navrstvíme plnku a potom nastrúhame druhú polovicu cesta,. Pečieme 30 min pri 180 °C.",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    }
  ],
