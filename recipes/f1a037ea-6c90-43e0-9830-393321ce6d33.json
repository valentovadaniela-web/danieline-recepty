  "instructions": [
    {
      "id": "df213297-49c8-4fe5-9143-6e9e73161d5f",
      "url": null,
      "text": "Kurča očistíme, pokrájame na menšie kúsky, osolíme a na horúcom masle prudko opečieme z oboch strán. Opečené mäso odložíme a na výpeku trošku opečieme odkvapkanú kukuricu s hrozienkami. ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "c2c19aba-da1d-4d27-a669-e1c602f9f206",
      "url": null,
      "text": "Kúsky mäsa poukladáme vedľa seba do jenskej misy, posypeme kukuricou s hrozienkami, polejeme smotanou, do ktorej sme zamiešali výpek, trochu okoreníme a dusíme pod pokrievkou v predhriatej rúre pri strednej teplote 40 min. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "ce88aa6c-4064-4ee9-a4d9-155ab40dcdae",
      "url": null,
      "text": "Na konci pečenia misu odkryjeme, pridáme hrášok, jedlo posypeme najemno posekanou petržlenovou vňaťou, vidličkou opatrne zamiešame a podávame s dusenou ryžou.",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    }
  ],
