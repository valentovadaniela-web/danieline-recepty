  "instructions": [
    {
      "id": "64c2d97c-59c0-46ac-bfa2-4c3fbb88862d",
      "url": null,
      "text": "Vajcia dobre vymiešame s maslom a práškovým cukrom. Pridáme múku s práškom do pečiva, orechy, mlieko a dobre premiešame. Vylejeme na vymastený a múkou posypaný plech, rovnomerne rozotrieme a pečieme pri teplote 175 °C cca 17 – 20 min.",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "e0cccb20-9dfd-424a-84f5-1d7862528270",
      "url": null,
      "text": "Vychladnuté cesto polejeme citrónovou alebo rumovou polevou: bielok vyšľaháme, pridáme cukor a šťavu z citróna alebo rum. Nakrájame ešte pred stuhnutím polevy.",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    }
