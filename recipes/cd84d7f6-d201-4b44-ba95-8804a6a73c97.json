  "instructions": [
    {
      "id": "4bdccc00-ab02-4b05-bd29-a2ed0f994f70",
      "url": null,
      "text": "V mise vymiesime múku so soľou a vodou (najlepšie rukou), cesto má byť husté. ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "42bd5bb9-0ef7-4404-8c4d-f2cfbfe509af",
      "url": null,
      "text": "Vytvarujeme z neho „bochník“, zabalíme ho do fólie a necháme minimálne 15 min v chladničke. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "fa50e0e7-7b66-4138-96ae-ffe3fde8b6be",
      "url": null,
      "text": "Nakrájame na tenšie plátky. Potom si jednotlivé plátky ponaťahujeme v rukách a začneme od vrchu z kraja „párať“, teda odtrhávať dlhé pásiky, najlepšie od stredu plátku. ",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "c02fa488-061f-45f6-b4d4-281802347da1",
      "url": null,
      "text": "Tie vkladáme do hrnca s vodou a varíme, až kým nevyplávajú na povrch, t.j. cca. 7 minút. ",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "050b01a9-66b4-4221-95aa-65a33e130951",
      "url": null,
      "text": "Potom párance vyberieme a polejeme olejom, pomiešame.",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    },
    {
      "id": "5d01d73a-73b9-413a-a0b8-b328e167fa60",
      "url": null,
      "text": "Surové zemiaky v šupke rozkrojíme na mesiačiky a opečieme. ",
      "image_url": null,
      "sort_order": 5,
      "is_group_header": false
    },
    {
      "id": "7b3c352d-b886-44cd-ad1c-820baa288017",
      "url": null,
      "text": "Potom ich s kúskom masla roztlačíme a pridáme k uvareným párancom. Všetko spolu zamiešame. ",
      "image_url": null,
      "sort_order": 6,
      "is_group_header": false
    },
    {
      "id": "e04110fa-2fd5-4ade-8bb6-841c817da2dd",
      "url": null,
      "text": "Slaninu nakrájame na kocky a opečieme. Podávame s opečenou slaninkou.",
      "image_url": null,
      "sort_order": 7,
      "is_group_header": false
    }
  ],
