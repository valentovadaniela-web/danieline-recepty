  "instructions": [
    {
      "id": "04b538f4-9d44-4d25-aff7-e1bbdf09ddd4",
      "url": null,
      "text": "Zo všetkých surovín vypracujeme hladké cesto. Zabalíme ho do mikroténového sáčka alebo potravinárskej fólie a uložíme do chladničky aspoň na 1 hodinu. Cesto možno pripraviť aj deň vopred.",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "d87f5cb0-1f75-436d-b4de-aa889bdd3997",
      "url": null,
      "text": "Po vychladení cesto rozdelíme na dve polovice. Jednu polovicu necháme v chladničke, aby sa pri práci príliš neohriala.",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "793ac320-a320-4abe-9c02-047ab2fa469d",
      "url": null,
      "text": "Z prvej polovice vytvarujeme valček a rozdelíme ho na kúsky približne veľkosti vlašského orecha. Z každého kúsku vyvaľkáme asi 5 cm dlhý valček, ktorý na koncoch mierne zúžime a vytvarujeme do podoby rožka.",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "594ece9d-d2ce-43c2-b741-06e375c20ed6",
      "url": null,
      "text": "Rožky ukladáme na plech vystlaný papierom na pečenie alebo jemne vymastený tukom.",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "ec617161-2398-40e4-8d54-1843814c2604",
      "url": null,
      "text": "Pečieme vo vopred vyhriatej rúre pri teplote 170 °C približne 15–16 minút, kým sú svetlo zlatisté. Nemali by výrazne zhnednúť.",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    },
    {
      "id": "cbe637bb-a625-4ff8-925c-812d230f2101",
      "url": null,
      "text": "Po vybratí z rúry ich necháme 1–2 minúty odpočinúť, potom ich ešte teplé opatrne obalíme v zmesi práškového a vanilkového cukru.",
      "image_url": null,
      "sort_order": 5,
      "is_group_header": false
    }
  ],
