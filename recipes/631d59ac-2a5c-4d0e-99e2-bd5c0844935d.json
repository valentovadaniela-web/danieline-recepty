  "instructions": [
    {
      "id": "02b4be36-d0ab-4865-a6a0-324946ca7f69",
      "url": null,
      "text": "Vymiešame maslo do penista. Pridáme cukor, vanilkový cukor (prípadne aj citrónovú kôru, škoricu) a vajcia a všetko zamiešame. Primiešame múku s práškom do pečiva. Za stáleho miešania prilievame mlieko. Všetko pomiešame ručným mixérom cca 2-3 min na najvyššom stupni.",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "fc818fe7-1d32-43c5-a1c6-c5175ec73bda",
      "url": null,
      "text": "Necháme postáť v chladničke 1 deň (alebo minimálne 2 hodiny).",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "7a4c90d5-433e-4386-bd36-eb145fdda4cb",
      "url": null,
      "text": "Do waflovača dávame po 1-2 polievkové lyžice cesta a pečieme cca 5 min.",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    }
