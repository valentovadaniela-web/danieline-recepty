  "instructions": [
    {
      "id": "229d1d3e-75de-499d-8869-7da4be6500dc",
      "url": null,
      "text": "Batáty aj mrkvu ošúpeme a nakrájame na malé kocky (mrkvu je lepšie pokrájať na veľmi malé kúsky, lebo batáty sa rozvaria oveľa rýchlejšie). ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "1af7cdba-0c3d-40c9-9fc7-564c3a6a271c",
      "url": null,
      "text": "V hrnci rozohrejeme olej, na ktorom opražíme najemno nasekaný cesnak. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "40107b7c-491c-470e-af25-7887f803d49a",
      "url": null,
      "text": "Pridáme batáty a mrkvu, posolíme a chvíľu restujeme. ",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "165509b9-fff2-4ce8-aaeb-d754a1634423",
      "url": null,
      "text": "Pridáme zázvor, zalejeme vodou, a necháme zovrieť. Necháme jemne vrieť, dokým mrkva aj batáty nie sú mäkké. ",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "9186a7ce-6894-47ce-ba1d-be230f32104b",
      "url": null,
      "text": "Potom rozmixujeme ponorným mixérom dohladka a dochutíme maslom a soľou. Podávame s kyslou smotanou a bazalkou.",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    }
  ],
