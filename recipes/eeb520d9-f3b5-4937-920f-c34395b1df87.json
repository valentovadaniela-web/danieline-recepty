  "instructions": [
    {
      "id": "815633da-5a9d-4bff-b6fe-52da5f999070",
      "url": null,
      "text": "Z pecňa chleba odkrojíme vršok a chlieb vydlabeme. ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "e9fd5178-057f-4d8a-a136-b2963daccd86",
      "url": null,
      "text": "Slaninu pokrájame na pásiky (kocky) a opražíme na oleji. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "2208cd02-d855-40ac-af2d-a90261664333",
      "url": null,
      "text": "Smotanu premiešame so syrom, pridáme papriku (na kocky), pažítku, vychladnutú slaninu a vegetu. Všetko dôkladne premiešame. ",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "8032cce3-5d51-4a24-baf3-3bae39275c74",
      "url": null,
      "text": "Tukom zo slaniny potrieme chlieb zvnútra aj zvonku, naplníme zmesou, prikryjeme odkrojenou strieškou a položíme na vymastený plech.  Vedľa rozložíme vydlabané kúsky chleba, ale nie hneď, lebo to bude tvrdé!!! (môžeme pokvapkať olejom zo slaniny). ",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "14731564-6126-4334-b913-9c988589d493",
      "url": null,
      "text": "Pečieme asi 10-15 minút vo vyhriatej rúre (zmes v chlebe musí byť teplá). ",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    },
    {
      "id": "4cb82add-32d1-4aa2-87b2-746fbcb4fb13",
      "url": null,
      "text": "Podáva sa bez prílohy a bez príboru, láme sa rukami a zapíja svetlým bielym vínom.",
      "image_url": null,
      "sort_order": 5,
      "is_group_header": false
    }
  ],
