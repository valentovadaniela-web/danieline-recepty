  "instructions": [
    {
      "id": "94378a95-0fda-4084-9dec-07d946d6a38e",
      "url": null,
      "text": "Zohrejeme rúru na 180 °C a vymastíme plech o veľkosti 20x20 cm. Vo veľkej mise zmiešame roztopené maslo, vajíčka, vanilkový cukor a kávu.",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "0f0567e1-6263-41a5-8356-caa9f091ad59",
      "url": null,
      "text": "Pridáme cukor a znova zamiešame. Cez sitko presypeme múku, kakao a soľ a zamiešame.",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "e4a8de66-d57c-47a7-86ad-c5bc96e2b907",
      "url": null,
      "text": "Potom do cesta primiešame čokoládové kúsky.",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "043ec500-7a69-4e11-933e-924c0d4f35be",
      "url": null,
      "text": "Vylejeme cesto na plech a aj na vrch nasypeme zopár čokoládových kúskov. Pečieme 30 min pri 180 °C.",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    }
  ],
