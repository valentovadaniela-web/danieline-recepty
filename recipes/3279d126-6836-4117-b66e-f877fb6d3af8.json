  "instructions": [
    {
      "id": "6678bd00-aa29-4ba3-b857-2e9127bb1104",
      "url": null,
      "text": "Vyšľahať vajíčka s kryštálovým cukrom do penista. Pridať múku s práškom do pečiva, orechy, strúhanku a sneh z bielkov. Plech vystlať oplátkami a vyliať na ne cesto. Upiecť (175 °C, 15 – 20 min).",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "8e9fc90d-9f6b-40e1-9f61-99c8d6f15253",
      "url": null,
      "text": "Kondenzované mlieko variť 2 hodiny vo vodnom kúpeli. Nechať vychladnúť, primiešať zmäknuté maslo a natrieť na vychladnuté cesto.",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "191e769b-a4e1-45e8-a57f-e458ebb1027d",
      "url": null,
      "text": "3 hrste posekaných orechov opražiť a po vychladnutí nasypať na koláč. Nechať v chlade aspoň 2 hodiny.",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    }
  ],
