  "instructions": [
    {
      "id": "58bc6161-bb29-4a2c-8939-6f2b8dcbb9cf",
      "url": null,
      "text": "Mäso nakrájame, zalejeme vodou, osolíme a dáme variť aj s korením do zmäknutia. Kapustu vyžmýkame, vodu si odložíme bokom. K zmäknutému mäsu pridáme kapustu a povaríme do zmäknutia kapusty (nie až do blata, musí ostať chrumkavá).",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "cb1d40ea-15c0-4f10-a52f-d54baf30b6a7",
      "url": null,
      "text": "Na masti speníme pretlačený cesnak, poprášime červenou paprikou, zalejeme vodou a potom pridáme k mäsu a kapuste. Ak je zmes málo kyslá, pridáme odloženú vodu z kapusty. Jucha musí ostať hustá. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "a3fe3505-2506-414a-b925-94c74ab5d77f",
      "url": null,
      "text": "Rozdelíme do zaváraninových pohárov, uzavrieme a sterilizujeme. Necháme po sterilizácii pomaly vychladnúť.",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    }
  ],
