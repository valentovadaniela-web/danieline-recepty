  "instructions": [
    {
      "id": "8d54e5e8-6735-4aa8-9bc3-57614282a72a",
      "url": null,
      "text": "Mäso prešpikujeme slaninou, posolíme a okoreníme. ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "54d06228-c1b0-4965-96e0-882014b02dc9",
      "url": null,
      "text": "Mrkvu, petržlen, zeler a cibuľu očistíme, pokrájame na kolieska alebo nastrúhame a upražíme na masle. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "34a680d2-33d4-4a7f-a85b-d58ebddbda1d",
      "url": null,
      "text": "Upraženú zeleninu dáme do jenskej misy, pridáme bobkový list a sviečkovicu, podlejeme vodou alebo vývarom a prikryté dusíme v rúre. ",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "ca44282e-edea-4ada-b085-27c229474d4e",
      "url": null,
      "text": "Počas pečenia mäso otáčame a podlievame výpekom, podľa potreby dolievame vodu. ",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "54de7234-fe2e-4e89-ad3f-4f6953eb9795",
      "url": null,
      "text": "Mäkké mäso vyberieme a dáme preč bobkový list. ",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    },
    {
      "id": "2f78f9ac-6f1e-493d-a7d4-bc877659acf0",
      "url": null,
      "text": "Šťavu aj so zeleninou rozmixujeme a dáme variť. ",
      "image_url": null,
      "sort_order": 5,
      "is_group_header": false
    },
    {
      "id": "1a01c1bd-0c71-4fa1-b1f6-2aa753ee99d0",
      "url": null,
      "text": "Zahustíme šľahačkou zmiešanou s hladkou múkou a cukrom. Zjemníme maslom. Dochutíme citrónovou šťavou alebo horčicou.",
      "image_url": null,
      "sort_order": 6,
      "is_group_header": false
    },
    {
      "id": "ad86003f-4f6e-426d-8677-5a429539cfc3",
      "url": null,
      "text": "Podávame s knedľou, prípadne aj s brusnicovou omáčkou.",
      "image_url": null,
      "sort_order": 7,
      "is_group_header": false
    }
  ],
