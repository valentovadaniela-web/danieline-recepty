  "instructions": [
    {
      "id": "051636c5-142f-4b8c-b1af-3746c5e90b39",
      "url": null,
      "text": "Rozvaľkané lístkové cesto na papieri na pečenie posypeme 1 PL kryštálového cukru a 1 PL hnedého cukru. Lyžicou alebo valčekom povtláčame cukor do cesta. Prikryjeme druhým papierom na pečenie, otočíme a aj z tejto strany posypeme PL kryštálového a 1 PL hnedého cukru, ktorý povtláčame do cesta.",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "8fa84c24-6c2f-40bb-9e1c-281eb7b8571f",
      "url": null,
      "text": "Dlhšie strany cesta zahneme z oboch strán až k stredu. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "b7aeb5d1-a7d9-4e7a-84bc-f3d6b4da6042",
      "url": null,
      "text": "Posypeme cukrom a znovu preložíme od krajov do stredu. Posypeme cukrom a tentoraz preložíme celé z jednej strany. ",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "8fff77df-1f71-44e2-9569-46f3a3bd18f2",
      "url": null,
      "text": "Nakrájame na cca 1 cm hrubé pláty. Uložíme na plech vystlaný papierom na pečenie v dostatočných vzdialenostiach (cca 3 x 4 ks na plech).",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "b0237372-f116-420c-8b57-9411b2cc327c",
      "url": null,
      "text": "Upečieme v predhriatej rúre na 180 °C cca 20 min do zlatista.",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    }
  ],
