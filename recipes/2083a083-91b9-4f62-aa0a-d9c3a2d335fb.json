  "instructions": [
    {
      "id": "923254b6-0c12-4113-9342-5ccdc659a09a",
      "url": null,
      "text": "Mleté mäso ochutíme soľou a mletým čiernym korením (koreninami). Vajcia uvaríme natvrdo. Očistené šampiňóny nakrájame a opražíme na masle s cibuľou.",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "55a2398c-d312-4a53-bf2b-c553c5af3e97",
      "url": null,
      "text": "Uvarené vajcia rozkrojíme pozdĺžne na polovice. Vyberieme žĺtok a jamku vyplníme šampiňónmi.",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "ccb98c63-6e0f-4055-9ee5-9ea4ba8e5b81",
      "url": null,
      "text": "Vajcia obalíme mäsom. Na jednej strane vytvarujeme papuľku ježka, oči a nos vyrobíme z celého čierneho korenia. Namiesto pichliačov použijeme neuvarené cestoviny, ktoré zapichneme tak, aby tvorili max. 1 cm dlhé pichliače (dlhšie by sa pri pečení ohli).",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "a0b3555e-9890-4e00-9a57-12750a6843b9",
      "url": null,
      "text": "Ježkov dáme na vymastený plech a zakryjeme alobalom. Pečieme 30 – 35 min pri 200 °C.",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    }
  ],
