  "instructions": [
    {
      "id": "27355599-c603-4e6f-a7a6-3e9119aa574d",
      "url": null,
      "text": "Očistený, umytý kel pokrájame na rezance a dáme do vriacej slanej vody. ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "efe9ada0-32a8-4973-8d75-e17dd4f4b287",
      "url": null,
      "text": "Pridáme rascu, korenie, majorán a očistené, na kocky pokrájané zemiaky. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "99957d4a-4161-44dc-bf94-38d439b24cda",
      "url": null,
      "text": "Z oleja a múky pripravíme zápražku, pridáme postrúhanú cibuľu, rozotretý cesnak a do ružova opražíme. Potom pridáme trochu sladkej papriky, zalejeme studenou vodou, prilejeme k uvarenému kelu, ešte povaríme a podávame.",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    }
