  "instructions": [
    {
      "id": "f35a3271-bf13-40d3-94ea-1110be6a9de4",
      "url": null,
      "text": "Do väčšej misy dáme všetky ingrediencie, pridáme mäso a premiešame. Prikryjeme a 1-2 hod necháme v chladničke.",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "ec92dded-d3da-4296-a230-49d2c6aab226",
      "url": null,
      "text": "Na fóliu poukladáme na seba mäso do vysokého úzkeho pásu (cca 50 x 15 cm) a zatočíme pevne do fólie. Na krajoch zagumičkujeme. Necháme zamraziť.",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "c16c2e30-6c35-4174-83a8-d21dac1bd09c",
      "url": null,
      "text": "Hodinu pred prípravou vyberieme z mrazničky, aby rolka trochu zmäkla. Nakrájame na čo najužšie kolieska.",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "02a7e3c1-2404-4293-a61e-34505b1e8d62",
      "url": null,
      "text": "Nakrájané mäso dáme do hlbšej panvice pomaly dusiť. Keď je mäso hotové, odkryjeme a necháme zapiecť do chrumkava. Môžeme ešte pridať korenie alebo oregano.",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "66a68bd2-feeb-4d78-b6ee-2eacd6a1f62e",
      "url": null,
      "text": " Podávame s hranolkami a zeleninou.",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    }
  ],
