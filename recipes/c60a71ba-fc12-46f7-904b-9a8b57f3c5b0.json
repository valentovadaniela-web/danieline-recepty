  "instructions": [
    {
      "id": "d7952e4d-364c-4747-a019-027f9596d53a",
      "url": null,
      "text": "Maslo rozpustíme a pridáme do mlieka. Pridáme žĺtky, vanilkový a škoricový cukor a mleté orechy. Múku a práškový cukor preosejeme a všetko zmiešame dokopy. Necháme asi hodinku odstáť a pečieme.",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "64018ab6-e158-45e3-988d-7c7a16aacda1",
      "url": null,
      "text": "Oplátkovač nastavený na stredný ohrev rozohrejeme, potrieme voskom obaleným v handričke (teplom nasiakne handrička voskom) a nalejeme do stredu 1 polievkovú lyžicu cesta. Hneď privrieme a pritlačíme, kým nahlas syčí. Okraje, ktoré pretečú orežeme. Oplátky pečieme cca 45-50 sek. Ak sa nelepia, netreba oplátkovač už viac natierať voskom.",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "4fb10c3b-b27a-4d67-86b7-d9245d98e821",
      "url": null,
      "text": "Ak robíme trubičky, rolujeme ich ešte zahorúca na oplátkovači na varechu (sú horúce, treba používať rukavice).",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "47436a1c-6a9c-4e2f-aa6f-d89eab67e3a5",
      "url": null,
      "text": "Oplátky oddeľujeme príborovým nožom, položíme na rovnú dosku a zaťažíme druhou doskou, aby ostali rovné.",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    }
  ],
