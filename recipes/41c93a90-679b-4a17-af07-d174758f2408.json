  "instructions": [
    {
      "id": "49f4c059-cfa6-4615-a2a2-72b552e0bae9",
      "url": null,
      "text": "Tekvicu vydlabať (jaderník vyhodiť), umyť a nakrájať na kocky. ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "0bd57f73-779f-4556-ac0e-754722c20c14",
      "url": null,
      "text": "Zemiaky nakrájať na kocky a spolu s tekvicovými kockami opiecť na oleji. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "308aafe4-5f2f-448f-9167-50cc48069512",
      "url": null,
      "text": "Zaliať vodou, pridať nakrájanú cibuľu, petržlen a dusiť do zmäknutia tekvice. ",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "ed0093cb-670d-4df3-8ea2-4681d70ddc84",
      "url": null,
      "text": "Pridať mleté korenie, vegetu, papriku, štipku muškátového oriešku, kari. ",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "b326aad2-cdd2-494e-9177-8a86e581e5e3",
      "url": null,
      "text": "Rozmixujeme polievku a prilejeme smotanu na varenie. Spolu ešte zvaríme.",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    },
    {
      "id": "31f774f2-9bc8-40eb-a1a4-ae7358d3c7ef",
      "url": null,
      "text": "Podávame s osmaženými kockami chleba a posypeme väčšími kúskami orechov a petržlenovou vňaťou..",
      "image_url": null,
      "sort_order": 5,
      "is_group_header": false
    }
  ],
