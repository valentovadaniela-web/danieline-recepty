  "instructions": [
    {
      "id": "f72e20b8-b8cc-4ad2-9e2b-1b40e8f12689",
      "url": null,
      "text": "Z mlieka, pudingových práškov a cukru uvaríme hustý puding. \n",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "b46d47a2-74a7-4c59-8e26-95a9ec9ff50e",
      "url": null,
      "text": "Ešte do horúceho pridáme kyslú smotanu. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "f09aabe4-45f3-43b2-9121-07657c4ed2fd",
      "url": null,
      "text": "Bielky vyšľaháme na tuhý sneh a pridáme ho tiež do kyslého smotanového pudingu, opatrne premiešame, aby sme nerozbili sneh. ",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "121fb234-603f-4060-906c-38b545088913",
      "url": null,
      "text": "Dochutíme strúhanou citrónovou kôrou. ",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "64feedba-b8a5-458a-b520-017bfac5755a",
      "url": null,
      "text": "Rúru predhrejeme na 180 °C. ",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    },
    {
      "id": "087b36b2-3ff3-442e-8ab2-c63045a16bfa",
      "url": null,
      "text": "Na cesto vymiešame maslo s cukrom, potom po jednom pridáme žĺtky. ",
      "image_url": null,
      "sort_order": 5,
      "is_group_header": false
    },
    {
      "id": "85cfcc60-9901-4542-a725-b1ef4aea5c8e",
      "url": null,
      "text": "Múku zmiešanú s práškom do pečiva preosejeme, ochutíme trochou soli a pridáme do maslovej vaječnej hmoty. ",
      "image_url": null,
      "sort_order": 6,
      "is_group_header": false
    },
    {
      "id": "493b3d2f-2855-4a46-9466-43cdb8ad7f64",
      "url": null,
      "text": "Spracujeme z neho rovnomerné cesto a rozdelíme ho na 2 časti v pomere asi 60 : 40. ",
      "image_url": null,
      "sort_order": 7,
      "is_group_header": false
    },
    {
      "id": "45f30ea6-b282-419b-a04d-b653ae011e7d",
      "url": null,
      "text": "Na papieri na pečenie rozvaľkáme väčšiu časť a preložíme ju aj s papierom na plech (27 x 38 cm) a ručne roztlačíme, aby rovnomerne vyplnila plech. Navrstvíme plnku. ",
      "image_url": null,
      "sort_order": 8,
      "is_group_header": false
    },
    {
      "id": "d8e02a30-8364-4cd1-9848-b174f9818585",
      "url": null,
      "text": "Z menšej časti cesta vyvaľkáme šúľky cesta a poukladáme ich do mriežky na plnku na plechu. ",
      "image_url": null,
      "sort_order": 9,
      "is_group_header": false
    },
    {
      "id": "691d74b3-e30b-4cee-a49f-736a01625a20",
      "url": null,
      "text": "Pečieme asi 35 minút. ",
      "image_url": null,
      "sort_order": 10,
      "is_group_header": false
    },
    {
      "id": "b92e332f-d633-4653-8aa9-6a6daf067c3c",
      "url": null,
      "text": "Po vychladnutí posypeme práškovým cukrom a podávame nakrájané na kocky.",
      "image_url": null,
      "sort_order": 11,
      "is_group_header": false
    }
  ],
