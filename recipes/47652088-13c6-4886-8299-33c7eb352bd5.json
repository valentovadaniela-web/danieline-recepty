  "instructions": [
    {
      "id": "c8c523d1-e1e2-4276-aa9c-290d8e55f642",
      "url": null,
      "text": "Vymiešať žĺtky, Palmarin, cukor. Pridať sneh z bielkov a múku s práškom do pečiva. Vmiešať preosiate kakao.",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "e4674eea-4fb2-4954-8091-70073be8ad4f",
      "url": null,
      "text": "Rozotrieť na plech a upiecť (180 °C, 20 min). Na vychladnutý koláč natrieť lekvár.",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "5081802f-c616-4955-a4f6-f2f4d68b384d",
      "url": null,
      "text": "Vodu a kryštálový cukor uvariť na číry sirup. Do horúceho zamiešať orechy. Ochladiť. Do vlažného vmiešať maslo.",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "8c567106-6aed-48d8-9060-44cab7925626",
      "url": null,
      "text": "Natrieť na koláč, zarovnať a poliať čokoládovou polevou.",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    }
  ],
