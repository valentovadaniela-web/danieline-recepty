  "instructions": [
    {
      "id": "714100bd-dc78-43b0-be50-6336708e64df",
      "url": null,
      "text": "Na dosku preosejeme múku s práškom do pečiva. Pridáme cukor, maslo, vajcia a zamiesime cesto. Polovicu cesta rozvaľkáme medzi 2 papiermi na pečenie, preložíme na vymastený a múkou vysypaný plech, trochu posypeme strúhankou a priamo na cesto postrúhame jablká, ktoré posypeme škoricou a kryštálovým cukrom. ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "2b7e2967-465c-4b96-b0e4-dff1e02a2a3e",
      "url": null,
      "text": "Navrch dáme druhú rozvaľkanú polovicu cesta, na okrajoch pritlačíme, poprepichujeme vidličkou a vo vyhriatej rúre upečieme doružova (175 °C – 30 min). Upečený koláč posypeme cukrom a necháme vychladnúť.",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    }
  ],
