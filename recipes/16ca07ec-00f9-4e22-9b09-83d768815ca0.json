  "instructions": [
    {
      "id": "16423bbe-5a2c-4711-9629-74fa85896acb",
      "url": null,
      "text": "Do kvetináča dáme salám - tú aby stála na spodnej strane zrežeme a upevníme rožkami – prekrojenými pozdĺžne na polovicu, prípadne na koliečka.",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "1e1bd915-9617-4b91-8af9-03df29d779f2",
      "url": null,
      "text": "Nakrájame mrkvu, eidam na požadovanú hrúbku a potom rôzne tvary formičkami. Potom všetko na seba napichneme na špáradlá a zapichneme do salámy. Je lepšie si pred zapichnutím špáradla urobiť otvor ihlicou. Nakoniec nasypeme na rožky v kvetináči arašidy a zabalíme do celofánu.",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    }
