  "instructions": [
    {
      "id": "e7ae1c91-2bc0-499e-8080-56deeb3d8e30",
      "url": null,
      "text": "Žĺtky + cukor + vodu vymiešať do peny. Pridať orechy, múky s práškom do pečiva a sneh z bielkov. ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "2091bdbd-168c-4c3f-b6b0-d094289ba894",
      "url": null,
      "text": "Upiecť (pri 200°C – 15 min). Nechať vychladnúť.",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "92b61f09-b7d7-48ab-a9d9-c8dc80d18ef2",
      "url": null,
      "text": "Vymiešať maslo + cukor. ",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    },
    {
      "id": "9066d8ca-2c5e-426c-aa98-737a21371cf3",
      "url": null,
      "text": "Zvariť mlieko a múky po vychladnutí zmiešať s maslovou hmotou.",
      "image_url": null,
      "sort_order": 3,
      "is_group_header": false
    },
    {
      "id": "26d8d5e9-1656-4ad3-bfdb-33acda9cd398",
      "url": null,
      "text": "Natrieť na koláč a poliať čokoládovou polevou.",
      "image_url": null,
      "sort_order": 4,
      "is_group_header": false
    }
  ],
