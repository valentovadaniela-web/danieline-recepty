  "instructions": [
    {
      "id": "b1828828-bbca-4e26-a8b0-43f3116eab8d",
      "url": null,
      "text": "Šampiňóny ošúpeme, pokrájame na plátky, orestujeme na troške masla a odložíme nabok. ",
      "image_url": null,
      "sort_order": 0,
      "is_group_header": false
    },
    {
      "id": "1fbdf239-d9e9-481b-ab36-9cdfc6810ff0",
      "url": null,
      "text": "Slaninu, pokrájanú na kocky, vyškvaríme, zalejeme šľahačkou, pridáme postrúhanú Nivu. Do zmesi vložíme šampiňóny, posypeme korením a oreganom. Zmes prehrejeme a dáme na špagety uvarené „al dente“. ",
      "image_url": null,
      "sort_order": 1,
      "is_group_header": false
    },
    {
      "id": "e83bb7e6-9f07-44e7-9263-dcfd63f3a8e6",
      "url": null,
      "text": "Posypeme tvrdým strúhaným syrom (najlepšie parmezánom) a nadrobno nasekanou šunkovou salámou. Ozdobíme pažítkou alebo petržlenovou vňaťou.",
      "image_url": null,
      "sort_order": 2,
      "is_group_header": false
    }
  ],
